@{
    ViewData["Title"] = "Quote Generated – Microhire";
}

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet" />

<!-- Phosphor icons -->
<link rel="stylesheet" href="https://unpkg.com/%40phosphor-icons/web@2.1.1/src/index.css" />

<!-- Theme -->
<link rel="stylesheet" href="~/css/style.css" />
<link rel="stylesheet" href="~/css/style_fill.css" />
<link rel="stylesheet" href="~/css/style_regular.css" />

<style>
    .quote-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.8);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }

    .quote-overlay-content {
        background: white;
        border-radius: 16px;
        padding: 40px;
        max-width: 500px;
        width: 90%;
        text-align: center;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        animation: fadeIn 0.3s ease-out;
    }

    .quote-icon {
        font-size: 64px;
        color: #28a745;
        margin-bottom: 20px;
    }

    .quote-title {
        font-size: 28px;
        font-weight: 700;
        color: #1a1a1a;
        margin-bottom: 16px;
    }

    .quote-message {
        font-size: 16px;
        color: #666;
        margin-bottom: 32px;
        line-height: 1.5;
    }

    .quote-actions {
        display: flex;
        gap: 16px;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-primary {
        background: #007bff;
        color: white;
        border: none;
        padding: 12px 24px;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: background-color 0.2s;
    }

    .btn-primary:hover {
        background: #0056b3;
        color: white;
        text-decoration: none;
    }

    .btn-secondary {
        background: #f8f9fa;
        color: #6c757d;
        border: 1px solid #dee2e6;
        padding: 12px 24px;
        border-radius: 8px;
        font-size: 16px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
    }

    .btn-secondary:hover {
        background: #e9ecef;
        color: #495057;
        text-decoration: none;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(-20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Hide the original chat interface */
    .chat-box-main {
        display: none;
    }
</style>

<div class="quote-overlay">
    <div class="quote-overlay-content">
        <div class="quote-icon">
            <i class="ph ph-check-circle"></i>
        </div>

        <h1 class="quote-title">Quote Generated Successfully!</h1>

        <p class="quote-message">
            Great news! Your professional quote has been prepared. Open it in a new tab to review pricing and equipment details.
            PDF download from the browser is coming soon; use View quote for the full document.
        </p>

        <div class="quote-actions">
            <a href="@ViewData["QuoteUrl"]" target="_blank" rel="noopener noreferrer" class="btn-primary">
                <i class="ph ph-arrow-square-out"></i>
                View quote
            </a>

            <a href="@Url.Action("Reset", "Chat")" class="btn-secondary">
                <i class="ph ph-arrow-clockwise"></i>
                Start New Quote
            </a>
        </div>
    </div>
</div>

<!-- Keep the original chat structure hidden for consistency -->
<div class="chat-box-main" style="display: none;">
    <!-- Original chat content would go here -->
</div>
