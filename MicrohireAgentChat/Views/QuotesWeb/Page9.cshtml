@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService
@model QuoteAllFields

@{
    Layout = "_LayoutQuote";
    ViewData["Title"] = $"Technical Services";
    ViewBag.Page = 9;
}

<style>
    .services-page {
        padding: 2rem;
        font-family: 'Inter', sans-serif;
    }
    
    .page-header {
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid #E71E25;
    }
    
    .page-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #1a1a2e;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.25rem;
    }
    
    .page-subtitle {
        font-size: 0.875rem;
        color: #888;
    }
    
    .services-table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 2rem;
    }
    
    .services-table th {
        background: linear-gradient(135deg, #1a1a2e 0%, #2d2d44 100%);
        color: white;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 1rem;
        text-align: left;
    }
    
    .services-table th:last-child {
        text-align: right;
    }
    
    .services-table td {
        padding: 1rem;
        font-size: 0.9rem;
        border-bottom: 1px solid #e0e0e0;
        vertical-align: middle;
    }
    
    .services-table tr:nth-child(even) {
        background: #f8f9fa;
    }
    
    .services-table tr:hover {
        background: #f0f0f0;
    }
    
    .tech-name {
        font-weight: 600;
        color: #1a1a2e;
    }
    
    .task-name {
        color: #555;
    }
    
    .qty-cell {
        text-align: center;
        font-weight: 500;
    }
    
    .time-cell {
        font-size: 0.85rem;
        color: #666;
    }
    
    .hours-cell {
        text-align: center;
        font-weight: 500;
        color: #E71E25;
    }
    
    .total-cell {
        text-align: right;
        font-weight: 600;
        color: #1a1a2e;
    }
    
    .labour-summary {
        background: linear-gradient(135deg, #E71E25 0%, #c0392b 100%);
        color: white;
        padding: 1.5rem 2rem;
        border-radius: 8px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .summary-label {
        font-size: 1rem;
        font-weight: 500;
    }
    
    .summary-value {
        font-size: 1.75rem;
        font-weight: 700;
    }
    
    .no-services {
        padding: 3rem;
        text-align: center;
        background: #f8f9fa;
        border-radius: 8px;
        color: #888;
    }
    
    .no-services-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
    }
    
    .no-services-text {
        font-size: 1.1rem;
        margin-bottom: 0.5rem;
    }
    
    .no-services-subtext {
        font-size: 0.875rem;
    }
</style>

<div class="services-page">
    <div class="page-header">
        <h1 class="page-title">Technical Services</h1>
        <div class="page-subtitle">@Model.EventTitle</div>
    </div>
    
    @if (Model.LabourRows != null && Model.LabourRows.Any())
    {
        <table class="services-table">
            <thead>
                <tr>
                    <th>Technician</th>
                    <th>Task</th>
                    <th style="width: 60px; text-align: center;">Qty</th>
                    <th style="width: 130px;">Start</th>
                    <th style="width: 130px;">Finish</th>
                    <th style="width: 70px; text-align: center;">Hours</th>
                    <th style="width: 100px;">Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.LabourRows)
                {
                    <tr>
                        <td class="tech-name">@row.Description</td>
                        <td class="task-name">@row.Task</td>
                        <td class="qty-cell">@row.Qty</td>
                        <td class="time-cell">@row.Start</td>
                        <td class="time-cell">@row.Finish</td>
                        <td class="hours-cell">@row.Hrs</td>
                        <td class="total-cell">@row.Total</td>
                    </tr>
                }
            </tbody>
        </table>
        
        <div class="labour-summary">
            <span class="summary-label">Labour Total</span>
            <span class="summary-value">@Model.LabourTotal</span>
        </div>
    }
    else
    {
        <div class="no-services">
            <div class="no-services-icon">👤</div>
            <div class="no-services-text">No technical services included</div>
            <div class="no-services-subtext">Technical personnel can be added upon request</div>
        </div>
    }
</div>
