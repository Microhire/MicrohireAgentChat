@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService
@model QuoteAllFields

@{
    Layout = "_LayoutQuote";
    ViewData["Title"] = $"Overview";
    ViewBag.Page = 2;
}

<style>
    .overview-page {
        padding: 2rem;
        font-family: 'Inter', sans-serif;
    }
    
    .overview-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 2rem;
        padding-bottom: 1.5rem;
        border-bottom: 2px solid #ca1a20;
    }
    
    .client-info {
        flex: 1;
    }
    
    .client-name {
        font-size: 1.25rem;
        font-weight: 600;
        color: #1a1a2e;
        margin-bottom: 0.25rem;
    }
    
    .client-org {
        font-size: 1rem;
        color: #555;
        margin-bottom: 0.25rem;
    }
    
    .client-email {
        font-size: 0.875rem;
        color: #888;
    }
    
    .greeting-section {
        margin: 2rem 0;
    }
    
    .greeting-text {
        font-size: 1.1rem;
        font-weight: 500;
        color: #1a1a2e;
        margin-bottom: 1rem;
    }
    
    .intro-text {
        font-size: 0.95rem;
        line-height: 1.7;
        color: #555;
        text-align: justify;
        margin-bottom: 2rem;
    }
    
    .details-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2rem;
        margin-bottom: 2rem;
    }
    
    .detail-section {
        background: #f8f9fa;
        padding: 1.5rem;
        border-radius: 8px;
        border-left: 4px solid #ca1a20;
    }
    
    .detail-section-title {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #ca1a20;
        margin-bottom: 1rem;
    }
    
    .detail-row {
        display: flex;
        margin-bottom: 0.75rem;
    }
    
    .detail-label {
        font-size: 0.875rem;
        font-weight: 600;
        color: #1a1a2e;
        min-width: 140px;
    }
    
    .detail-value {
        font-size: 0.875rem;
        color: #555;
        flex: 1;
    }
    
    .schedule-section {
        margin-top: 2rem;
    }
    
    .schedule-title {
        font-size: 0.875rem;
        font-weight: 500;
        color: #888;
        font-style: italic;
        margin-bottom: 1rem;
    }
    
    .schedule-table {
        width: 100%;
        border-collapse: collapse;
    }
    
    .schedule-table th {
        background: #ca1a20;
        color: white;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 0.75rem 1rem;
        text-align: left;
    }
    
    .schedule-table td {
        padding: 0.75rem 1rem;
        font-size: 0.875rem;
        border-bottom: 1px solid #e0e0e0;
    }
    
    .schedule-table tr:nth-child(even) {
        background: #f8f9fa;
    }
    
    .schedule-label {
        font-weight: 600;
        color: #1a1a2e;
    }
    
    .total-highlight {
        background: linear-gradient(135deg, #1a1a2e 0%, #2d2d44 100%);
        color: white;
        padding: 1.5rem;
        border-radius: 8px;
        margin-top: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    
    .total-label {
        font-size: 1rem;
        font-weight: 500;
    }
    
    .total-amount {
        font-size: 1.5rem;
        font-weight: 700;
    }
</style>

<div class="overview-page">
    <div class="overview-header">
        <div class="client-info">
            <div class="client-name">@Model.ContactName</div>
            <div class="client-org">@Model.Client</div>
            <div class="client-email">@Model.Email</div>
        </div>
    </div>
    
    <div class="greeting-section">
        @{
            var firstName = string.IsNullOrWhiteSpace(Model.ContactName) ? "Client" : Model.ContactName.Split(' ')[0];
        }
        <div class="greeting-text">Dear @firstName,</div>
        <p class="intro-text">
            Thank you for the opportunity to present our audio-visual production services for your upcoming event at @Model.Location. 
            We are pleased to provide our proposal in the following pages, based on the information we have received 
            and our recommendations for a seamless and successful event. Our team is committed to achieving your event 
            objectives and welcome the opportunity to discuss your requirements and any budget parameters in further detail. 
            If you have any questions or need further information, please do not hesitate to contact me on the details below. 
            Thank you again and we look forward to speaking to you soon.
        </p>
    </div>
    
    <div class="details-grid">
        <div class="detail-section">
            <div class="detail-section-title">Venue Details</div>
            <div class="detail-row">
                <span class="detail-label">Location</span>
                <span class="detail-value">@Model.Location</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Address</span>
                <span class="detail-value">@Model.Address</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Room</span>
                <span class="detail-value">@Model.Room</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Event Dates</span>
                <span class="detail-value">@Model.DateRange</span>
            </div>
        </div>
        
        <div class="detail-section">
            <div class="detail-section-title">Your Account Manager</div>
            <div class="detail-row">
                <span class="detail-label">Name</span>
                <span class="detail-value">@Model.AccountMgrName</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Mobile</span>
                <span class="detail-value">@Model.AccountMgrMobile</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Email</span>
                <span class="detail-value">@Model.AccountMgrEmail</span>
            </div>
            <div class="detail-row">
                <span class="detail-label">Delivery Contact</span>
                <span class="detail-value">@Model.DeliveryContact</span>
            </div>
        </div>
    </div>
    
    <div class="schedule-section">
        <div class="schedule-title">Please confirm the following dates and times are accurate:</div>
        <table class="schedule-table">
            <thead>
                <tr>
                    <th>Activity</th>
                    <th>Date</th>
                    <th>Time</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="schedule-label">Setup</td>
                    <td>@Model.SetupDate</td>
                    <td>@Model.SetupTime</td>
                </tr>
                <tr>
                    <td class="schedule-label">Rehearsal</td>
                    <td>@Model.RehearsalDate</td>
                    <td>@Model.RehearsalTime</td>
                </tr>
                <tr>
                    <td class="schedule-label">Event Start</td>
                    <td>@Model.EventStartDate</td>
                    <td>@Model.EventStartTime</td>
                </tr>
                <tr>
                    <td class="schedule-label">Event End</td>
                    <td>@Model.EventEndDate</td>
                    <td>@Model.EventEndTime</td>
                </tr>
            </tbody>
        </table>
    </div>
    
    <div class="total-highlight">
        <span class="total-label">Quote Total (inc GST)</span>
        <span class="total-amount">@Model.GrandTotalIncGst</span>
    </div>
</div>
