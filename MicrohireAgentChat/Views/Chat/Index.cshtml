        font-weight: 600;
        color: #333;
    }
    .scenario-info small {
        font-size: 12px;
        color: #666;
    }
</style>

@section Scripts {
    <script>
        (() => {
          const messagesWrap = document.getElementById('messagesWrap');
          const sendForm     = document.getElementById('sendForm');
          const resetForm    = document.getElementById('resetForm');
          const input        = document.getElementById('textInput');
          const sendBtn      = document.getElementById('sendBtn');

          const sendToken  = sendForm.querySelector('input[name="__RequestVerificationToken"]').value;
          const resetToken = resetForm ? resetForm.querySelector('input[name="__RequestVerificationToken"]').value : null;

          function scrollToBottom() { messagesWrap.scrollTop = messagesWrap.scrollHeight; }

          function updateProgressBar() {
            const stepEl = document.getElementById('progressStepData');
            if (!stepEl) return;
            const step = stepEl.dataset.step || '';
            const bar = document.querySelector('.chat-box-progress');
            if (bar) bar.className = 'chat-box-progress' + (step ? ' ' + step : '');
          }

          // ----- Typing bubble -----
          function addTypingBubble() {
            if (document.getElementById('typing-bubble')) return;
            const wrap = document.createElement('div');
            wrap.id = 'typing-bubble';
            wrap.className = 'chat-message message-recived typing-bubble';
            wrap.innerHTML = `
              <div class="chat-message-box">
                <div class="chat-message-avatar">
                  <img src="${'@Url.Content("~/images/avatar.png")'}" alt="">
                </div>
                <div class="chat-message-body">
                  <div class="typing-ellipsis" aria-label="Isla is typing">
                    <span>.</span><span>.</span><span>.</span>
                  </div>
                </div>
              </div>`;
            messagesWrap.appendChild(wrap);
            scrollToBottom();
          }
          function removeTypingBubble() { const t = document.getElementById('typing-bubble'); if (t) t.remove(); }
          const REQUEST_TIMEOUT_MS = 90000;

          function createRequestTimeout(timeoutMs = REQUEST_TIMEOUT_MS) {
            const controller = new AbortController();
            const timeoutId = window.setTimeout(() => controller.abort(), timeoutMs);
            return {
              signal: controller.signal,
              clear: () => window.clearTimeout(timeoutId)
            };
          }

          function escapeHtml(text) {
            return (text || '')
              .replace(/&/g, '&amp;')
              .replace(/</g, '&lt;')
              .replace(/>/g, '&gt;');
          }

          function appendAssistantFallbackMessage(text) {
            const fallbackText = text || 'Sorry, I hit a temporary issue and could not complete that step. Please send your last message again and I will continue.';
            const fallbackDiv = document.createElement('div');
            fallbackDiv.className = 'chat-message message-recived';
            fallbackDiv.innerHTML = `
              <div class="chat-message-box">
                <div class="chat-message-avatar">
                  <img src="${'@Url.Content("~/images/avatar.png")'}" alt="">
                </div>
                <div class="chat-message-body">
                  <div class="chat-text">${escapeHtml(fallbackText)}</div>
                </div>
              </div>`;
            messagesWrap.appendChild(fallbackDiv);
            scrollToBottom();
          }

          function fallbackMessageForError(err) {
            if (err && err.name === 'AbortError') {
              return 'I am still processing that request and it took longer than expected. Please send your last message again and I will continue.';
            }
            return 'Sorry, I hit a temporary issue and could not complete that step. Please send your last message again and I will continue.';
          }

          // ----- Hydrate agent UI JSON blocks (imageGallery, timePicker, multitime) -----
          function hydrateUiBlocks(root) {
            const nodes = (root || messagesWrap).querySelectorAll('script.ui-json[type="application/json"]');
            nodes.forEach(node => {
              let payload;
              try { payload = JSON.parse(node.textContent.trim() || "{}"); } catch { return; }
              const holder = document.createElement('div');

              // Handle both array format and object format for payload.ui
              const uiItems = Array.isArray(payload.ui) ? payload.ui : (payload.ui ? [payload.ui] : []);

              uiItems.forEach(item => {
                // image gallery -> cards from your theme
                if (item.type === 'imageGallery') {
                  const wrap = document.createElement('div');
                  wrap.className = 'message-card-wrap';
                  const urls = (item.data && (item.data.items || [])) || [];
                  urls.forEach(u => {
                    const card = document.createElement('div');
                    card.className = 'message-card-box';
                    const img  = document.createElement('img');
                    img.className = 'message-card-box-img';
                    img.src = u; img.alt = 'option';

                    const body = document.createElement('div');
                    body.className = 'message-card-box-content';
                    const h6 = document.createElement('h6'); h6.textContent = 'Tap to select';
                    const p  = document.createElement('p');  p.textContent  = '';
                    const btn = document.createElement('button'); btn.type = 'button'; btn.textContent = 'SELECT';
                    btn.onclick = () => sendSelection('image', u);

                    body.appendChild(h6); body.appendChild(p); body.appendChild(btn);
                    card.appendChild(img); card.appendChild(body);
                    wrap.appendChild(card);
                  });
                  holder.appendChild(wrap);
                }

                // time picker -> simple inputs inside cards
                if (item.type === 'timePicker') {
                  const wrap = document.createElement('div');
                  wrap.className = 'message-card-wrap';
                  const labels = (item.data && item.data.items) || [];
                  const times = {};
                  labels.forEach(label => {
                    const card = document.createElement('div');
                    card.className = 'message-card-box';
                    const body = document.createElement('div');
                    body.className = 'message-card-box-content';
                    const h6 = document.createElement('h6'); h6.textContent = `${label} Time`;
                    const inp = document.createElement('input'); inp.type = 'time';
                    inp.onchange = () => { times[label] = inp.value; };
                    const btn = document.createElement('button'); btn.type = 'button'; btn.textContent = 'SET';
                    btn.onclick = () => { times[label] = inp.value; };
                    body.appendChild(h6); body.appendChild(inp); body.appendChild(btn);
                    card.appendChild(body);
                    wrap.appendChild(card);
                  });
                  const done = document.createElement('button'); done.type = 'button'; done.textContent = 'Done';
                  done.style.marginTop = '8px'; done.onclick = () => sendSelection('times', times);
                  holder.appendChild(wrap);
                  holder.appendChild(done);
                }

                // multitime picker -> matches server-side structure
                if (item.type === 'multitime') {
                  const wrap = document.createElement('div');
                  wrap.className = 'isla-multitime';
                  const stepMinutes = item.stepMinutes || 15;
                  const dateIso = item.date || '';
                  wrap.setAttribute('data-step', stepMinutes);
                  wrap.setAttribute('data-date', dateIso);

                  // Title
                  if (item.title) {
                    const title = document.createElement('div');
                    title.className = 'isla-timepicker-title';
                    title.textContent = item.title;
                    wrap.appendChild(title);
                  }

                  // Grid container
                  const grid = document.createElement('div');
                  grid.className = 'isla-multitime-grid';

                  // Create picker inputs
                  const pickers = item.pickers || [];
                  pickers.forEach(picker => {
                    const itemDiv = document.createElement('div');
                    itemDiv.className = 'isla-mt-item';

                    const label = document.createElement('label');
                    label.textContent = picker.label || picker.name || '';
                    itemDiv.appendChild(label);

                    const input = document.createElement('input');
                    input.type = 'time';
                    input.className = 'mt-input';
                    input.setAttribute('data-name', picker.name || '');
                    input.step = stepMinutes * 60;
                    input.value = picker.default || picker.value || '09:00';
                    itemDiv.appendChild(input);

                    grid.appendChild(itemDiv);
                  });

                  wrap.appendChild(grid);

                  // Submit button
                  const submitBtn = document.createElement('button');
                  submitBtn.type = 'button';
                  submitBtn.className = 'btn-apply-multitime';
                  submitBtn.textContent = item.submitLabel || 'Submit';
                  wrap.appendChild(submitBtn);

                  holder.appendChild(wrap);
                }
              });

              if (holder.children.length > 0) {
                node.insertAdjacentElement('afterend', holder);
                node.remove(); // hide raw JSON
              }
            });
          }

          // Send a UI selection as a compact user message to keep the flow going
          async function sendSelection(kind, value) {
            const text = `[UI_SELECT] ${JSON.stringify({ kind, value })}`;
            sendBtn.disabled = true;
            addTypingBubble();
            let sendReqTimeout = null;
            let continueReqTimeout = null;

            try {
              sendReqTimeout = createRequestTimeout();
              const res = await fetch('@Url.Action("SendPartial", "Chat")', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                  'RequestVerificationToken': sendToken
                },
                body: new URLSearchParams({ text }),
                signal: sendReqTimeout.signal
              });
              sendReqTimeout.clear();
              if (!res.ok) throw new Error('Request failed');
              const textRes = await res.text();
              let html = textRes;
              let continueNeeded = false;
              try {
                const j = JSON.parse(textRes);
                if (j.continueNeeded && j.html) { html = j.html; continueNeeded = true; }
              } catch (_) {}
              messagesWrap.innerHTML = html;
              hydrateUiBlocks(messagesWrap);
              updateProgressBar();
              scrollToBottom();
              if (continueNeeded) {
                continueReqTimeout = createRequestTimeout();
                const contRes = await fetch('@Url.Action("ContinuePartial", "Chat")', {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'RequestVerificationToken': sendToken
                  },
                  body: new URLSearchParams({ __RequestVerificationToken: sendToken }),
                  signal: continueReqTimeout.signal
                });
                continueReqTimeout.clear();
                if (!contRes.ok) throw new Error('Continue failed');
                const fullHtml = await contRes.text();
                messagesWrap.innerHTML = fullHtml;
                hydrateUiBlocks(messagesWrap);
                updateProgressBar();
                scrollToBottom();
              }
            } catch (err) {
              console.error(err);
              appendAssistantFallbackMessage(fallbackMessageForError(err));
            } finally {
              if (sendReqTimeout) sendReqTimeout.clear();
              if (continueReqTimeout) continueReqTimeout.clear();
              removeTypingBubble();
              sendBtn.disabled = false;
              input.focus();
            }
          }
          window.sendSelection = sendSelection; // expose for gallery buttons

          // Initial hydrate + scroll (in case agent already returned UI blocks)
          hydrateUiBlocks(messagesWrap);
          updateProgressBar();
          scrollToBottom();

          // ----- SEND -----
          sendForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const text = (input.value || '').trim();
            if (!text) return;

            // Immediately add user message to conversation
            const userMessageDiv = document.createElement('div');
            userMessageDiv.className = 'chat-message message-sent';
            userMessageDiv.innerHTML = `
              <div class="chat-message-box">
                <div class="chat-message-body">
                  <div class="chat-text">${escapeHtml(text)}</div>
                </div>
              </div>`;
            messagesWrap.appendChild(userMessageDiv);
            input.value = '';
            scrollToBottom();

            sendBtn.disabled = true;
            addTypingBubble();
            let sendReqTimeout = null;
            let continueReqTimeout = null;

            try {
              sendReqTimeout = createRequestTimeout();
              const res = await fetch('@Url.Action("SendPartial", "Chat")', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                  'RequestVerificationToken': sendToken
                },
                body: new URLSearchParams({ text }),
                signal: sendReqTimeout.signal
              });
              sendReqTimeout.clear();
              if (!res.ok) throw new Error('Request failed');
              const textRes = await res.text();
              let html = textRes;
              let continueNeeded = false;
              try {
                const j = JSON.parse(textRes);
                if (j.continueNeeded && j.html) {
                  html = j.html;
                  continueNeeded = true;
                }
              } catch (_) { /* not JSON, use as HTML */ }
              messagesWrap.innerHTML = html;
              hydrateUiBlocks(messagesWrap);
              updateProgressBar();
              scrollToBottom();

              if (continueNeeded) {
                continueReqTimeout = createRequestTimeout();
                const contRes = await fetch('@Url.Action("ContinuePartial", "Chat")', {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'RequestVerificationToken': sendToken
                  },
                  body: new URLSearchParams({ __RequestVerificationToken: sendToken }),
                  signal: continueReqTimeout.signal
                });
                continueReqTimeout.clear();
                if (!contRes.ok) throw new Error('Continue failed');
                const fullHtml = await contRes.text();
                messagesWrap.innerHTML = fullHtml;
                hydrateUiBlocks(messagesWrap);
                updateProgressBar();
                scrollToBottom();
              }
            } catch (err) {
              console.error(err);
              appendAssistantFallbackMessage(fallbackMessageForError(err));
            } finally {
              if (sendReqTimeout) sendReqTimeout.clear();
              if (continueReqTimeout) continueReqTimeout.clear();
              removeTypingBubble();
              sendBtn.disabled = false;
              input.focus();
            }
          });

          // ----- RESET (New Thread) -----
          if (resetForm) {
            resetForm.addEventListener('submit', async (e) => {
              e.preventDefault();
              try {
                const res = await fetch('@Url.Action("ResetPartial", "Chat")', {
                  method: 'POST',
                  headers: { 'RequestVerificationToken': resetToken }
                });
                if (!res.ok) throw new Error('Reset failed');
                const html = await res.text();
                messagesWrap.innerHTML = html;
                hydrateUiBlocks(messagesWrap);
                updateProgressBar();
                scrollToBottom();
                input.focus();
              } catch (err) {
                console.error(err);
                alert(err.message || 'Failed to reset');
              }
            });
          }

          // ----- DEV MODE: Conversation Replay -----
          const startReplayBtn = document.getElementById('startReplayBtn');
          const nextReplayBtn = document.getElementById('nextReplayBtn');
          const replayStatus = document.getElementById('replayStatus');
          const testScenarioModal = document.getElementById('testScenarioModal');
          const closeModalBtn = document.getElementById('closeModalBtn');
          const scenarioBtns = document.querySelectorAll('.scenario-btn');

          // Show modal when clicking Test button
          if (startReplayBtn) {
            startReplayBtn.addEventListener('click', () => {
              testScenarioModal.style.display = 'flex';
            });
          }

          // Close modal
          if (closeModalBtn) {
            closeModalBtn.addEventListener('click', () => {
              testScenarioModal.style.display = 'none';
            });
          }

          // Close modal when clicking outside
          if (testScenarioModal) {
            testScenarioModal.addEventListener('click', (e) => {
              if (e.target === testScenarioModal) {
                testScenarioModal.style.display = 'none';
              }
            });
          }

          // Handle scenario selection (scripted replay vs AI auto-test)
          scenarioBtns.forEach(btn => {
            btn.addEventListener('click', async () => {
              const scenario = btn.dataset.scenario;
              const autoTestScenario = btn.dataset.autotest;
              testScenarioModal.style.display = 'none';

              if (autoTestScenario !== undefined) {
                // AI Auto-Test flow
                try {
                  const res = await fetch('@Url.Action("StartAutoTest", "Chat")', {
                    method: 'POST',
                    headers: {
                      'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                      'RequestVerificationToken': sendToken
                    },
                    body: new URLSearchParams({ scenario: autoTestScenario })
                  });
                  const data = await res.json();
                  if (!data.success) throw new Error(data.error || 'Failed to start auto-test');
                  
                  // Reset chat messages UI for new test
                  messagesWrap.innerHTML = '';
                  
                  const panel = document.getElementById('autoTestPanel');
                  const statusEl = document.getElementById('autoTestStatus');
                  statusEl.textContent = `${data.personaName}`;
                  panel.style.display = 'block';
                  window.__autoTestRunning = true;
                  window.__autoTestPaused = false;
                  window.__autoTestAbort = false;
                  runAutoTestLoop();
                } catch (err) {
                  console.error(err);
                  alert(err.message || 'Failed to start AI auto-test');
                }
                return;
              }

              // Scripted replay flow
              try {
                startReplayBtn.disabled = true;
                startReplayBtn.textContent = 'Starting...';

                const res = await fetch('@Url.Action("StartConversationReplay", "Chat")', {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'RequestVerificationToken': sendToken
                  },
                  body: new URLSearchParams({ scenario })
                });

                const data = await res.json();
                if (data.success) {
                  startReplayBtn.style.display = 'none';
                  nextReplayBtn.style.display = 'inline-block';
                  replayStatus.style.display = 'inline';
                  replayStatus.textContent = `${data.scenarioName}: ${data.messageCount} messages`;
                  nextReplayBtn.disabled = false;
                } else {
                  throw new Error(data.error || 'Failed to start replay');
                }
              } catch (err) {
                console.error(err);
                alert(err.message || 'Failed to start conversation replay');
                startReplayBtn.disabled = false;
                startReplayBtn.innerHTML = '<i class="ph ph-play"></i> Test';
              }
            });
          });

          // ----- AI Auto-Test loop and controls -----
          const autoTestPanel = document.getElementById('autoTestPanel');
          const autoTestStatus = document.getElementById('autoTestStatus');
          const autoTestStep = document.getElementById('autoTestStep');
          const autoTestGenerated = document.getElementById('autoTestGenerated');
          const autoTestPauseBtn = document.getElementById('autoTestPauseBtn');
          const autoTestStopBtn = document.getElementById('autoTestStopBtn');
          const autoTestDelay = document.getElementById('autoTestDelay');
          const maxSteps = 30;

          function updateMilestones(m) {
            if (!m) return;
            const set = (id, done) => {
              const el = document.getElementById(id);
              if (el) { el.className = 'atp-badge ' + (done ? 'on' : 'off'); }
            };
            set('m-name', m.nameProvided);
            set('m-status', m.customerStatusProvided);
            set('m-org', m.organizationProvided);
            set('m-contact', m.contactInfoProvided);
            set('m-event', m.eventDetailsProvided);
            set('m-equipment', m.equipmentDiscussed);
            set('m-schedule', m.scheduleConfirmed);
            set('m-summary', m.quoteSummaryShown);
            set('m-quote', m.quoteGenerated);
            set('m-confirmed', m.quoteConfirmed);
          }

          let autoTestAbortCtrl = null;

          async function runAutoTestLoop() {
            while (window.__autoTestRunning && !window.__autoTestAbort) {
              while (window.__autoTestPaused && !window.__autoTestAbort) {
                await new Promise(r => setTimeout(r, 300));
              }
              if (window.__autoTestAbort) break;
              autoTestAbortCtrl = new AbortController();
              try {
                const res = await fetch('@Url.Action("RunAutoTestStep", "Chat")', {
                  method: 'POST',
                  headers: { 'RequestVerificationToken': sendToken },
                  signal: autoTestAbortCtrl.signal
                });
                const data = await res.json();
                if (!data.success) {
                  autoTestStatus.textContent = 'Error: ' + (data.error || 'Unknown');
                  autoTestStatus.style.color = '#d32f2f';
                  break;
                }
                if (data.html) {
                  messagesWrap.innerHTML = data.html;
                  hydrateUiBlocks(messagesWrap);
                  updateProgressBar();
                  scrollToBottom();
                }
                if (data.generatedMessage) {
                  autoTestGenerated.textContent = 'Customer said: ' + data.generatedMessage;
                }
                autoTestStep.textContent = 'Step ' + (data.stepNumber || 0) + '/' + maxSteps;
                if (data.milestones) updateMilestones(data.milestones);
                if (data.isComplete) {
                  autoTestStatus.textContent = 'Complete: ' + (data.completionState?.completionReason || 'Done');
                  autoTestStatus.style.color = '#2e7d32';
                  window.__autoTestRunning = false;
                  break;
                }
                const delay = parseInt(autoTestDelay?.value || 3000, 10) || 3000;
                await new Promise(r => setTimeout(r, Math.max(500, delay)));
              } catch (err) {
                if (err.name === 'AbortError') break;
                console.error(err);
                autoTestStatus.textContent = 'Error: ' + err.message;
                window.__autoTestRunning = false;
                break;
              }
            }
            autoTestAbortCtrl = null;
            if (window.__autoTestAbort) {
              autoTestStatus.textContent = 'Stopped';
            }
          }

          if (startAutoTestBtn) {
            startAutoTestBtn.addEventListener('click', () => {
              testScenarioModal.style.display = 'flex';
            });
          }
          if (autoTestPauseBtn) {
            autoTestPauseBtn.addEventListener('click', () => {
              window.__autoTestPaused = !window.__autoTestPaused;
              autoTestPauseBtn.textContent = window.__autoTestPaused ? 'Resume' : 'Pause';
            });
          }
          if (autoTestStopBtn) {
            autoTestStopBtn.addEventListener('click', async () => {
              window.__autoTestAbort = true;
              window.__autoTestRunning = false;
              autoTestStopBtn.disabled = true;
              if (autoTestAbortCtrl) autoTestAbortCtrl.abort();
              try {
                await fetch('@Url.Action("StopAutoTest", "Chat")', {
                  method: 'POST',
                  headers: { 'RequestVerificationToken': sendToken }
                });
              } catch (e) { /* ignore */ }
            });
          }

          if (nextReplayBtn) {
            nextReplayBtn.addEventListener('click', async () => {
              try {
                nextReplayBtn.disabled = true;
                nextReplayBtn.innerHTML = '<i class="ph ph-spinner ph-spin"></i> Sending...';

                const res = await fetch('@Url.Action("GetNextReplayMessage", "Chat")', {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'RequestVerificationToken': sendToken
                  }
                });

                const data = await res.json();
                if (data.success) {
                  // Auto-fill the input with the next message
                  input.value = data.message;
                  replayStatus.textContent = data.completed ? 'Completed!' : `${data.remaining} messages remaining`;

                  if (data.completed) {
                    nextReplayBtn.style.display = 'none';
                    startReplayBtn.style.display = 'inline-block';
                    startReplayBtn.disabled = false;
                    startReplayBtn.innerHTML = '<i class="ph ph-play"></i> Test';
                    replayStatus.style.display = 'none';
                  } else {
                    nextReplayBtn.disabled = false;
                    nextReplayBtn.innerHTML = '<i class="ph ph-fast-forward"></i> Next';
                  }
                } else {
                  if (data.error === 'Replay completed') {
                    nextReplayBtn.style.display = 'none';
                    startReplayBtn.style.display = 'inline-block';
                    startReplayBtn.disabled = false;
                    startReplayBtn.innerHTML = '<i class="ph ph-play"></i> Test';
                    replayStatus.style.display = 'none';
                  } else {
                    throw new Error(data.error || 'Failed to get next message');
                  }
                }
              } catch (err) {
                console.error(err);
                alert(err.message || 'Failed to get next replay message');
                nextReplayBtn.disabled = false;
                nextReplayBtn.innerHTML = '<i class="ph ph-fast-forward"></i> Next';
              }
            });
          }
        })();
    </script>
}
