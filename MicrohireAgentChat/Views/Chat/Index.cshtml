@using MicrohireAgentChat.Services
@model IEnumerable<DisplayMessage>

@{
    ViewData["Title"] = "Isla – Microhire";
}

<meta name="lead-token" content="@(ViewData["LeadToken"] ?? "")" />

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet" />

<!-- Phosphor icons (bundle) -->
@* <link rel="preconnect" href="https://unpkg.com" crossorigin />
<link rel="stylesheet" href="https://unpkg.com/%40phosphor-icons/web@2.1.1/src/index.css" />
 *@
<!-- Your theme -->
<link rel="stylesheet" href="~/css/style.css" />
<link rel="stylesheet" href="~/css/style_fill.css" />
<link rel="stylesheet" href="~/css/style_regular.css" />

<!-- Tiny inline styles only for typing bubble (using @@keyframes to avoid Razor errors) -->
<style>
    .typing-bubble .chat-message-body { padding-right: 12px; }
    .typing-ellipsis {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 22px;
      line-height: 1;
      padding: 10px 12px;
      background: #f7f8fc;
      border: 1px solid #e6e8ef;
      border-radius: 12px;
    }
    .typing-ellipsis span {
      display: inline-block;
      width: .45em;
      text-align: center;
      opacity: .25;
      animation: typing-pulse 1.1s ease-in-out infinite;
    }
    .typing-ellipsis span:nth-child(2) { animation-delay: .15s; }
    .typing-ellipsis span:nth-child(3) { animation-delay: .30s; }
    @@keyframes typing-pulse {
      0%, 80%, 100% { transform: translateY(0); opacity: .25; }
      40%           { transform: translateY(-4px); opacity: 1; }
    }
</style>

<div class="chat-box-main">
    <div class="chat-box-header">
        <!-- adjust classes (first-step-active/second-step-active) as your flow progresses -->
        <div class="chat-box-progress @ViewData["ProgressStep"]"></div>
        <div class="chat-box-progress-titles">
            <span>Venue</span>
            <span>Services</span>
            <span>Review</span>
            <span>Quote</span>
        </div>
    </div>

    <div class="chat-box-body">
        <div asp-validation-summary="All" class="text-danger" role="alert" style="margin: 8px 12px; font-size: 14px;"></div>
        <!-- Image Preview Modal -->
        <div id="islaPreviewOverlay" class="isla-preview-overlay" style="display: none;">
            <div class="isla-preview-backdrop"></div>
            <div class="isla-preview-modal">
                <button type="button" class="isla-preview-close" aria-label="Close preview">&times;</button>
                
                <div class="isla-preview-content">
                    <button type="button" class="isla-preview-nav prev" aria-label="Previous image">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
                    </button>
                    
                    <div class="isla-preview-image-container">
                        <img id="islaPreviewImage" src="" alt="Preview" />
                        <div class="isla-preview-info-overlay">
                            <div id="islaPreviewLabel" class="isla-preview-label"></div>
                            <div id="islaPreviewCounter" class="isla-preview-counter"></div>
                        </div>
                    </div>

                    <button type="button" class="isla-preview-nav next" aria-label="Next image">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
                    </button>
                </div>

                <div class="isla-preview-footer">
                    <button type="button" class="isla-preview-select">Select This Option</button>
                </div>
            </div>
        </div>

        <div id="islaFloorplanOverlay" class="isla-floorplan-overlay" style="display: none;" aria-modal="true" role="dialog" aria-label="Floor plan">
            <div class="isla-floorplan-backdrop" data-isla-floorplan-close></div>
            <div class="isla-floorplan-modal">
                <button type="button" class="isla-floorplan-close" data-isla-floorplan-close aria-label="Close floor plan">&times;</button>
                <img id="islaFloorplanImage" src="" alt="Venue floor plan" />
            </div>
        </div>

        <script src="~/js/isla-chat-dates.js" asp-append-version="true"></script>
        <div id="messagesWrap" class="chat-box-wrap">
            @await Html.PartialAsync("_Messages", Model)
        </div>

        <div class="chat-box-type">
            <form id="sendForm" asp-action="Send" method="post" class="w-100">
                @Html.AntiForgeryToken()
                <input id="textInput" name="text" type="text" placeholder="Type your message..." autocomplete="off" />
            </form>

            <button id="sendBtn" type="submit" form="sendForm" title="Send">
                <i class="ph ph-caret-right"></i>
            </button>

            @if (ViewData["DevModeEnabled"] as bool? == true && ViewData["IsDevelopment"] as bool? == true)
            {
                <button id="startReplayBtn" type="button" class="btn btn-outline-primary ms-2" title="Start Test Conversation">
                    <i class="ph ph-play"></i> Test
                </button>

                <button id="nextReplayBtn" type="button" class="btn btn-outline-secondary ms-1" title="Send Next Test Message" style="display:none">
                    <i class="ph ph-fast-forward"></i> Next
                </button>

                <span id="replayStatus" class="ms-2 text-muted" style="display:none"></span>

                <button id="startAutoTestBtn" type="button" class="btn btn-outline-success ms-2" title="AI Auto-Test (runs like a customer)">
                    <i class="ph ph-robot"></i> Auto Test
                </button>

                <form id="resetForm" asp-action="Reset" method="post" class="ms-2">
                    @Html.AntiForgeryToken()
                    <button class="btn btn-link text-decoration-none" type="submit" title="Start New Conversation">
                        <i class="ph ph-plus-circle"></i> New Quote
                    </button>
                </form>
            }
        </div>
    </div>
</div>

@if (ViewData["DevModeEnabled"] as bool? == true && ViewData["IsDevelopment"] as bool? == true)
{
<!-- Auto-Test Floating Panel (outside chat-box-main to avoid CSS bleed) -->
<style>
    #autoTestPanel { position: fixed; bottom: 20px; right: 20px; width: 340px; z-index: 10000; background: #fff; border: 1px solid #ccc; border-radius: 10px; box-shadow: 0 6px 24px rgba(0,0,0,.15); padding: 14px 16px; font-family: 'Inter', sans-serif; font-size: 13px; color: #333; }
    #autoTestPanel button { all: revert; font-family: inherit; font-size: 12px; cursor: pointer; border-radius: 4px; padding: 3px 10px; border: 1px solid #999; background: #f5f5f5; color: #333; }
    #autoTestPanel button:hover { background: #e0e0e0; }
    #autoTestPanel button.atp-stop { border-color: #d32f2f; color: #d32f2f; }
    #autoTestPanel button.atp-stop:hover { background: #ffebee; }
    #autoTestPanel button.atp-close { all: revert; font-family: inherit; font-size: 18px; cursor: pointer; background: none; border: none; color: #999; padding: 0; line-height: 1; }
    #autoTestPanel button.atp-close:hover { color: #333; }
    #autoTestPanel .atp-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
    #autoTestPanel .atp-name { font-weight: 700; font-size: 14px; color: #1a73e8; }
    #autoTestPanel .atp-controls { display: flex; align-items: center; gap: 6px; margin-bottom: 8px; }
    #autoTestPanel .atp-step { background: #333; color: #fff; font-size: 11px; padding: 2px 8px; border-radius: 10px; font-weight: 600; }
    #autoTestPanel .atp-delay { margin-bottom: 8px; }
    #autoTestPanel .atp-delay label { font-size: 11px; color: #888; display: block; margin-bottom: 2px; }
    #autoTestPanel .atp-delay input[type=range] { width: 100%; margin: 0; }
    #autoTestPanel .atp-delay output { font-size: 11px; color: #555; }
    #autoTestPanel .atp-msg { font-style: italic; font-size: 12px; color: #555; background: #f9f9f9; border: 1px solid #eee; border-radius: 6px; padding: 6px 8px; margin-bottom: 8px; max-height: 50px; overflow-y: auto; word-break: break-word; }
    #autoTestPanel .atp-milestones { display: flex; flex-wrap: wrap; gap: 4px; }
    #autoTestPanel .atp-badge { font-size: 10px; padding: 2px 6px; border-radius: 8px; color: #fff; font-weight: 600; }
    #autoTestPanel .atp-badge.off { background: #bbb; }
    #autoTestPanel .atp-badge.on  { background: #2e7d32; }
</style>
<div id="autoTestPanel" style="display:none;">
    <div class="atp-header">
        <span id="autoTestStatus" class="atp-name"></span>
        <button type="button" class="atp-close" onclick="document.getElementById('autoTestPanel').style.display='none'">&times;</button>
    </div>
    <div class="atp-controls">
        <span id="autoTestStep" class="atp-step"></span>
        <button id="autoTestPauseBtn" type="button">Pause</button>
        <button id="autoTestStopBtn" type="button" class="atp-stop">Stop</button>
    </div>
    <div class="atp-delay">
        <label>Delay between steps</label>
        <input id="autoTestDelay" type="range" value="3000" min="500" max="10000" step="500" oninput="this.nextElementSibling.value = this.value + 'ms'" />
        <output>3000ms</output>
    </div>
    <div id="autoTestGenerated" class="atp-msg"></div>
    <div class="atp-milestones">
        <span id="m-name" class="atp-badge off">Name</span>
        <span id="m-status" class="atp-badge off">Status</span>
        <span id="m-org" class="atp-badge off">Org</span>
        <span id="m-contact" class="atp-badge off">Contact</span>
        <span id="m-event" class="atp-badge off">Event</span>
        <span id="m-equipment" class="atp-badge off">Equipment</span>
        <span id="m-schedule" class="atp-badge off">Schedule</span>
        <span id="m-summary" class="atp-badge off">Summary</span>
        <span id="m-quote" class="atp-badge off">Quote</span>
        <span id="m-confirmed" class="atp-badge off">Confirmed</span>
    </div>
</div>

<!-- Test Scenario Selection Modal -->
<div id="testScenarioModal" class="modal-overlay" style="display: none;">
    <div class="modal-content">
        <div class="modal-header">
            <h3>Select Test Scenario</h3>
            <button type="button" class="modal-close" id="closeModalBtn">&times;</button>
        </div>
        <div class="modal-body">
            <div class="scenario-category">
                <h4>🐛 Bug Reproduction Tests</h4>
                <p class="category-desc">Test scenarios that reproduce reported bugs</p>
                <div class="scenario-list">
                    <button class="scenario-btn bug-scenario" data-scenario="ai_stops_responding">
                        <span class="scenario-icon">⚠️</span>
                        <span class="scenario-info">
                            <strong>AI Stops Responding</strong>
                            <small>Reproduces bug where AI stops after time picker confirmation</small>
                        </span>
                    </button>
                    <button class="scenario-btn bug-scenario" data-scenario="time_picker_validation">
                        <span class="scenario-icon">⏰</span>
                        <span class="scenario-info">
                            <strong>Time Picker Validation</strong>
                            <small>Tests time picker edge cases and validation</small>
                        </span>
                    </button>
                    <button class="scenario-btn bug-scenario" data-scenario="time_picker_display_order">
                        <span class="scenario-icon">🔄</span>
                        <span class="scenario-info">
                            <strong>Time Picker Display Order</strong>
                            <small>Tests picker doesn't appear for room questions and shows correct order</small>
                        </span>
                    </button>
                    <button class="scenario-btn bug-scenario" data-scenario="skip_contact_info">
                        <span class="scenario-icon">📋</span>
                        <span class="scenario-info">
                            <strong>Skip Contact Info</strong>
                            <small>Tests that AI blocks quote without contact info</small>
                        </span>
                    </button>
                    <button class="scenario-btn bug-scenario" data-scenario="quote_generation_issues">
                        <span class="scenario-icon">📄</span>
                        <span class="scenario-info">
                            <strong>Quote Generation Issues</strong>
                            <small>Tests quote retry loops, context memory, and back-and-forth errors</small>
                        </span>
                    </button>
                    <button class="scenario-btn bug-scenario" data-scenario="thrive_zoom_no_assumption">
                        <span class="scenario-icon">🎯</span>
                        <span class="scenario-info">
                            <strong>Thrive Zoom/Teams Ask-Only</strong>
                            <small>Replays Thrive Boardroom path where Zoom/Teams is mentioned; assistant must ask for camera/mic/speakers instead of assuming</small>
                        </span>
                    </button>
                    <button class="scenario-btn bug-scenario" data-scenario="schedule_recognition_fix">
                        <span class="scenario-icon">📅</span>
                        <span class="scenario-info">
                            <strong>Schedule Recognition Fix</strong>
                            <small>Verifies schedule is recognised after time picker submit; no re-ask for schedule before quote</small>
                        </span>
                    </button>
                    <button class="scenario-btn bug-scenario" data-scenario="westin_brisbane_room_packages">
                        <span class="scenario-icon">🛠️</span>
                        <span class="scenario-info">
                            <strong>Westin Brisbane Room Packages</strong>
                            <small>Verifies AI recommends built-in AV packages (projector, speaker) for specific rooms</small>
                        </span>
                    </button>
                    <button class="scenario-btn bug-scenario" data-scenario="quote_modification">
                        <span class="scenario-icon">📝</span>
                        <span class="scenario-info">
                            <strong>Quote Modification</strong>
                            <small>Tests update_equipment (remove projector/screen, add mic) then create quote; optional regenerate_quote</small>
                        </span>
                    </button>
                    <button class="scenario-btn bug-scenario" data-scenario="image_gallery_preview">
                        <span class="scenario-icon">🖼️</span>
                        <span class="scenario-info">
                            <strong>Image Gallery Preview</strong>
                            <small>Tests the new image preview modal for rooms, layouts and equipment</small>
                        </span>
                    </button>
                    <button class="scenario-btn bug-scenario" data-scenario="ai_delay_memory_fix">
                        <span class="scenario-icon">🛡️</span>
                        <span class="scenario-info">
                            <strong>AI Delay & Memory Fix</strong>
                            <small>Verifies the fix for "brief delay" message and ensures context is preserved during retries</small>
                        </span>
                    </button>
                    <button class="scenario-btn bug-scenario" data-scenario="speaker_style_order">
                        <span class="scenario-icon">🔊</span>
                        <span class="scenario-info">
                            <strong>Speaker Style Order</strong>
                            <small>Verifies audio playback prompts speaker style (inbuilt vs external) before laptop questions for Elevate/Ballroom</small>
                        </span>
                    </button>
                    <button class="scenario-btn bug-scenario" data-scenario="another_quote_from_same_conversation">
                        <span class="scenario-icon">📋</span>
                        <span class="scenario-info">
                            <strong>Another Quote From Same Conversation</strong>
                            <small>First quote (Ballroom 2, 10 Mar), then "new quote for another event" and second quote (Elevate, 4 Apr). Second must get a new booking number.</small>
                        </span>
                    </button>
                </div>
            </div>

            <div class="scenario-category">
                <h4>🏢 Thrive Boardroom Test Flows</h4>
                <p class="category-desc">Comprehensive Thrive flow tests: happy path, capacity, presentations, video conferencing, equipment modification</p>
                <div class="scenario-list">
                    <button class="scenario-btn" data-scenario="thrive_simple_meeting">
                        <span class="scenario-icon">✅</span>
                        <span class="scenario-info">
                            <strong>Thrive Simple Meeting</strong>
                            <small>Happy path end-to-end: name, contact, thrive, date, schedule, equipment, create quote</small>
                        </span>
                    </button>
                    <button class="scenario-btn" data-scenario="thrive_too_many_attendees">
                        <span class="scenario-icon">👥</span>
                        <span class="scenario-info">
                            <strong>Thrive Too Many Attendees</strong>
                            <small>15+ attendees; agent should redirect away from Thrive to Elevate/Podium</small>
                        </span>
                    </button>
                    <button class="scenario-btn" data-scenario="thrive_presentations_full_av">
                        <span class="scenario-icon">📽️</span>
                        <span class="scenario-info">
                            <strong>Thrive Presentations Full AV</strong>
                            <small>2 presenters, slides, Mac laptops, clicker, flipchart; THRVAVP included, no duplicates</small>
                        </span>
                    </button>
                    <button class="scenario-btn" data-scenario="thrive_video_conference">
                        <span class="scenario-icon">📹</span>
                        <span class="scenario-info">
                            <strong>Thrive Video Conference</strong>
                            <small>Zoom/Teams mentioned; agent must ask for VC gear, never assume</small>
                        </span>
                    </button>
                    <button class="scenario-btn" data-scenario="thrive_own_laptop_adaptor">
                        <span class="scenario-icon">💻</span>
                        <span class="scenario-info">
                            <strong>Thrive Own Laptop + Adaptor</strong>
                            <small>User brings own laptop, needs USBC/HDMI adaptor</small>
                        </span>
                    </button>
                    <button class="scenario-btn" data-scenario="thrive_equipment_modification">
                        <span class="scenario-icon">✏️</span>
                        <span class="scenario-info">
                            <strong>Thrive Equipment Modification</strong>
                            <small>Quote summary then remove item, add flipchart; tests update_equipment and regenerate_quote</small>
                        </span>
                    </button>
                    <button class="scenario-btn" data-scenario="thrive_room_alias_bare">
                        <span class="scenario-icon">🏷️</span>
                        <span class="scenario-info">
                            <strong>Thrive Room Alias (bare)</strong>
                            <small>User says only "thrive" to select room; tests standalone token matching</small>
                        </span>
                    </button>
                </div>
            </div>
            
            <div class="scenario-category">
                <h4>📋 Standard Test Flows</h4>
                <p class="category-desc">General conversation flow tests with randomized data</p>
                <div class="scenario-list">
                    <button class="scenario-btn" data-scenario="random">
                        <span class="scenario-icon">🎲</span>
                        <span class="scenario-info">
                            <strong>Random Scenario</strong>
                            <small>Randomly selects from all standard scenarios</small>
                        </span>
                    </button>
                    <button class="scenario-btn" data-scenario="small_event">
                        <span class="scenario-icon">👥</span>
                        <span class="scenario-info">
                            <strong>Small Event</strong>
                            <small>15-25 attendees, boardroom meeting</small>
                        </span>
                    </button>
                    <button class="scenario-btn" data-scenario="large_conference">
                        <span class="scenario-icon">🎪</span>
                        <span class="scenario-info">
                            <strong>Large Conference</strong>
                            <small>300-500 attendees, major event</small>
                        </span>
                    </button>
                    <button class="scenario-btn" data-scenario="social_event">
                        <span class="scenario-icon">🎉</span>
                        <span class="scenario-info">
                            <strong>Social/Gala Event</strong>
                            <small>Dinner, gala, or social gathering</small>
                        </span>
                    </button>
                </div>
            </div>
            <div class="scenario-category">
                <h4>🤖 AI Auto-Test (GPT-4o customer)</h4>
                <p class="category-desc">AI generates realistic customer messages and runs the full flow automatically. Watch in real time.</p>
                <div class="scenario-list">
                    <button class="scenario-btn auto-test-scenario" data-autotest="random">
                        <span class="scenario-icon">🎲</span>
                        <span class="scenario-info">
                            <strong>Random</strong>
                            <small>AI customer with random persona and event</small>
                        </span>
                    </button>
                    <button class="scenario-btn auto-test-scenario" data-autotest="small_meeting">
                        <span class="scenario-icon">👥</span>
                        <span class="scenario-info">
                            <strong>Small Meeting</strong>
                            <small>8-25 people, boardroom style</small>
                        </span>
                    </button>
                    <button class="scenario-btn auto-test-scenario" data-autotest="large_conference">
                        <span class="scenario-icon">🎪</span>
                        <span class="scenario-info">
                            <strong>Large Conference</strong>
                            <small>200-500 attendees</small>
                        </span>
                    </button>
                    <button class="scenario-btn auto-test-scenario" data-autotest="social_event">
                        <span class="scenario-icon">🎉</span>
                        <span class="scenario-info">
                            <strong>Social Event</strong>
                            <small>Gala, dinner, or social gathering</small>
                        </span>
                    </button>
                    <button class="scenario-btn auto-test-scenario" data-autotest="thrive_boardroom">
                        <span class="scenario-icon">🪑</span>
                        <span class="scenario-info">
                            <strong>Thrive Boardroom</strong>
                            <small>Fixed layout, 4-10 people, no layout selection</small>
                        </span>
                    </button>
                    <button class="scenario-btn auto-test-scenario" data-autotest="ballroom_projector">
                        <span class="scenario-icon">📽️</span>
                        <span class="scenario-info">
                            <strong>Ballroom + Projector</strong>
                            <small>Ballroom 1/2, projector area &amp; dual projector test</small>
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
}

<style>
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }
    .modal-content {
        background: white;
        border-radius: 12px;
        max-width: 500px;
        width: 90%;
        max-height: 80vh;
        overflow-y: auto;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    }
    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 20px;
        border-bottom: 1px solid #e6e8ef;
    }
    .modal-header h3 {
        margin: 0;
        font-size: 18px;
        font-weight: 600;
    }
    .modal-close {
        background: none;
        border: none;
        font-size: 24px;
        cursor: pointer;
        color: #666;
        padding: 0;
        line-height: 1;
    }
    .modal-close:hover { color: #333; }
    .modal-body {
        padding: 16px 20px;
    }
    .scenario-category {
        margin-bottom: 20px;
    }
    .scenario-category h4 {
        margin: 0 0 4px 0;
        font-size: 14px;
        font-weight: 600;
        color: #333;
    }
    .category-desc {
        margin: 0 0 12px 0;
        font-size: 12px;
        color: #666;
    }
    .scenario-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .scenario-btn {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        background: #f7f8fc;
        border: 1px solid #e6e8ef;
        border-radius: 8px;
        cursor: pointer;
        text-align: left;
        transition: all 0.2s;
    }
    .scenario-btn:hover {
        background: #eef0f7;
        border-color: #d0d4e4;
    }
    .scenario-btn.bug-scenario {
        background: #fff5f5;
        border-color: #fecaca;
    }
    .scenario-btn.bug-scenario:hover {
        background: #fee2e2;
        border-color: #f87171;
    }
    .scenario-icon {
        font-size: 24px;
        flex-shrink: 0;
    }
    .scenario-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }
    .scenario-info strong {
        font-size: 14px;
        font-weight: 600;
        color: #333;
    }
    .scenario-info small {
        font-size: 12px;
        color: #666;
    }
</style>

@section Scripts {
    <script>
        (() => {
          const messagesWrap = document.getElementById('messagesWrap');
          const sendForm     = document.getElementById('sendForm');
          const resetForm    = document.getElementById('resetForm');
          const input        = document.getElementById('textInput');
          const sendBtn      = document.getElementById('sendBtn');

          const sendToken  = sendForm.querySelector('input[name="__RequestVerificationToken"]').value;
          const resetToken = resetForm ? resetForm.querySelector('input[name="__RequestVerificationToken"]').value : null;

          // Disable chat input if quote was already accepted (page refresh after signing)
          if ('@(ViewData["QuoteAccepted"])' === '1') {
            if (input) { input.disabled = true; input.placeholder = 'This chat session has ended.'; }
            if (sendBtn) { sendBtn.disabled = true; }
          }

          function scrollToBottom() { messagesWrap.scrollTop = messagesWrap.scrollHeight; }

          function updateProgressBar() {
            const stepEl = document.getElementById('progressStepData');
            if (!stepEl) return;
            const step = stepEl.dataset.step || '';
            const bar = document.querySelector('.chat-box-progress');
            if (bar) bar.className = 'chat-box-progress' + (step ? ' ' + step : '');
          }

          // ----- Typing bubble -----
          function addTypingBubble() {
            if (document.getElementById('typing-bubble')) return;
            const wrap = document.createElement('div');
            wrap.id = 'typing-bubble';
            wrap.className = 'chat-message message-recived typing-bubble';
            wrap.innerHTML = `
              <div class="chat-message-box">
                <div class="chat-message-avatar">
                  <img src="${'@Url.Content("~/images/avatar.png")'}" alt="">
                </div>
                <div class="chat-message-body">
                  <div class="typing-ellipsis" aria-label="Isla is typing">
                    <span>.</span><span>.</span><span>.</span>
                  </div>
                </div>
              </div>`;
            messagesWrap.appendChild(wrap);
            scrollToBottom();
          }
          function removeTypingBubble() { const t = document.getElementById('typing-bubble'); if (t) t.remove(); }
          /** innerHTML on messagesWrap removes the typing bubble; call this after every replace while a send is active */
          function ensureOutboundTypingVisible() {
            if ((window.__islaOutboundSendDepth || 0) > 0) {
              addTypingBubble();
              scrollToBottom();
            }
          }
          // Agent + quote (DB + Playwright PDF) can exceed 3m; stay above server WithChatOperationTimeoutAsync (180s) and quote sub-timeout (5m).
          const REQUEST_TIMEOUT_MS = 360000;

          function createRequestTimeout(timeoutMs = REQUEST_TIMEOUT_MS) {
            const controller = new AbortController();
            const timeoutId = window.setTimeout(() => controller.abort(), timeoutMs);
            return {
              signal: controller.signal,
              clear: () => window.clearTimeout(timeoutId)
            };
          }

          function escapeHtml(text) {
            return (text || '')
              .replace(/&/g, '&amp;')
              .replace(/</g, '&lt;')
              .replace(/>/g, '&gt;');
          }

          function appendAssistantFallbackMessage(text) {
            const fallbackText = text || 'Sorry, I hit a temporary issue and could not complete that step. Please send your last message again and I will continue.';
            const fallbackDiv = document.createElement('div');
            fallbackDiv.className = 'chat-message message-recived';
            fallbackDiv.innerHTML = `
              <div class="chat-message-box">
                <div class="chat-message-avatar">
                  <img src="${'@Url.Content("~/images/avatar.png")'}" alt="">
                </div>
                <div class="chat-message-body">
                  <div class="chat-text">${escapeHtml(fallbackText)}</div>
                </div>
              </div>`;
            messagesWrap.appendChild(fallbackDiv);
            scrollToBottom();
          }

          function fallbackMessageForError(err) {
            if (err && err.name === 'AbortError') {
              return 'I am still processing that request and it took longer than expected. Please send your last message again and I will continue.';
            }
            return 'Sorry, I hit a temporary issue and could not complete that step. Please send your last message again and I will continue.';
          }

          // ----- Hydrate agent UI JSON blocks (imageGallery, timePicker, multitime) -----
          function hydrateUiBlocks(root) {
            const nodes = (root || messagesWrap).querySelectorAll('script.ui-json[type="application/json"]');
            nodes.forEach(node => {
              let payload;
              try { payload = JSON.parse(node.textContent.trim() || "{}"); } catch { return; }
              const holder = document.createElement('div');

              // Handle both array format and object format for payload.ui
              const uiItems = Array.isArray(payload.ui) ? payload.ui : (payload.ui ? [payload.ui] : []);

              uiItems.forEach(item => {
                // image gallery -> cards from your theme
                if (item.type === 'imageGallery') {
                  const wrap = document.createElement('div');
                  wrap.className = 'message-card-wrap';
                  const urls = (item.data && (item.data.items || [])) || [];
                  urls.forEach(u => {
                    const card = document.createElement('div');
                    card.className = 'message-card-box';
                    const img  = document.createElement('img');
                    img.className = 'message-card-box-img';
                    img.src = u; img.alt = 'option';

                    const body = document.createElement('div');
                    body.className = 'message-card-box-content';
                    const h6 = document.createElement('h6'); h6.textContent = 'Tap to select';
                    const p  = document.createElement('p');  p.textContent  = '';
                    const btn = document.createElement('button'); btn.type = 'button'; btn.textContent = 'SELECT';
                    btn.onclick = () => sendSelection('image', u);

                    body.appendChild(h6); body.appendChild(p); body.appendChild(btn);
                    card.appendChild(img); card.appendChild(body);
                    wrap.appendChild(card);
                  });
                  holder.appendChild(wrap);
                }

                // time picker -> simple inputs inside cards
                if (item.type === 'timePicker') {
                  const wrap = document.createElement('div');
                  wrap.className = 'message-card-wrap';
                  const labels = (item.data && item.data.items) || [];
                  const times = {};
                  labels.forEach(label => {
                    const card = document.createElement('div');
                    card.className = 'message-card-box';
                    const body = document.createElement('div');
                    body.className = 'message-card-box-content';
                    const h6 = document.createElement('h6'); h6.textContent = `${label} Time`;
                    const inp = document.createElement('input'); inp.type = 'time';
                    inp.onchange = () => { times[label] = inp.value; };
                    const btn = document.createElement('button'); btn.type = 'button'; btn.textContent = 'SET';
                    btn.onclick = () => { times[label] = inp.value; };
                    body.appendChild(h6); body.appendChild(inp); body.appendChild(btn);
                    card.appendChild(body);
                    wrap.appendChild(card);
                  });
                  const done = document.createElement('button'); done.type = 'button'; done.textContent = 'Done';
                  done.style.marginTop = '8px'; done.onclick = () => sendSelection('times', times);
                  holder.appendChild(wrap);
                  holder.appendChild(done);
                }

                // multitime picker -> matches server-side structure
                if (item.type === 'multitime') {
                  const wrap = document.createElement('div');
                  wrap.className = 'isla-multitime';
                  const stepMinutes = item.stepMinutes || 15;
                  const dateIso = item.date || '';
                  wrap.setAttribute('data-step', stepMinutes);
                  wrap.setAttribute('data-date', dateIso);

                  // Title
                  if (item.title) {
                    const title = document.createElement('div');
                    title.className = 'isla-timepicker-title';
                    title.textContent = item.title;
                    wrap.appendChild(title);
                  }

                  // Grid container
                  const grid = document.createElement('div');
                  grid.className = 'isla-multitime-grid';

                  // Create picker inputs
                  const pickers = item.pickers || [];
                  pickers.forEach(picker => {
                    const itemDiv = document.createElement('div');
                    itemDiv.className = 'isla-mt-item';

                    const label = document.createElement('label');
                    label.textContent = picker.label || picker.name || '';
                    itemDiv.appendChild(label);

                    const input = document.createElement('input');
                    input.type = 'time';
                    input.className = 'mt-input';
                    input.setAttribute('data-name', picker.name || '');
                    input.step = stepMinutes * 60;
                    input.value = picker.default || picker.value || '09:00';
                    itemDiv.appendChild(input);

                    grid.appendChild(itemDiv);
                  });

                  wrap.appendChild(grid);

                  // Submit button
                  const submitBtn = document.createElement('button');
                  submitBtn.type = 'button';
                  submitBtn.className = 'btn-apply-multitime';
                  submitBtn.textContent = item.submitLabel || 'Submit';
                  wrap.appendChild(submitBtn);

                  holder.appendChild(wrap);
                }

                if (item.type === 'contactForm') {
                  const wrap = document.createElement('div');
                  wrap.className = 'isla-form-card isla-contact-form';
                  wrap.setAttribute('data-contact-form', '');
                  wrap.innerHTML = `
                    <div class="isla-form-title">${item.title || 'Before we begin, please share your details'}</div>
                    <div class="isla-form-grid two-col">
                      <div class="isla-form-field"><label>First name</label><input type="text" data-cf-first-name autocomplete="given-name" /></div>
                      <div class="isla-form-field"><label>Last name</label><input type="text" data-cf-last-name autocomplete="family-name" /></div>
                      <div class="isla-form-field"><label>Organisation</label><input type="text" data-cf-organisation autocomplete="organization" /></div>
                      <div class="isla-form-field"><label>Location</label><input type="text" data-cf-location autocomplete="address-level2" /></div>
                      <div class="isla-form-field"><label>Email</label><input type="email" data-cf-email autocomplete="email" /></div>
                      <div class="isla-form-field"><label>Phone (optional)</label><input type="tel" data-cf-phone autocomplete="tel" /></div>
                    </div>
                    <div class="isla-form-actions">
                      <button type="button" class="isla-form-submit" data-contact-submit>${item.submitLabel || 'Send details'}</button>
                    </div>
                    <div class="isla-form-error" data-contact-error style="display:none"></div>`;
                  holder.appendChild(wrap);
                }

                if (item.type === 'eventForm') {
                  const wrap = document.createElement('div');
                  wrap.className = 'isla-form-card isla-event-form';
                  wrap.setAttribute('data-event-form', '');

                  const roomOptions = item.roomOptions || [];
                  const venueLabel = item.venueLabel || 'Westin Brisbane';
                  const selectedSlug = item.selectedRoomSlug || '';
                  const setupOptions = item.setupOptions || [];
                  const schedule = item.schedule || {};

                  const roomOptsHtml = (!selectedSlug ? '<option value="" selected disabled>Select room</option>' : '') +
                    roomOptions.map(ro => {
                      const sel = selectedSlug && String(ro.id) === String(selectedSlug) ? 'selected' : '';
                      return `<option value="${ro.id || ''}" ${sel}>${ro.label || ro.id || ''}</option>`;
                    }).join('');

                  const setupHtml = setupOptions.map(opt => {
                    const selected = (item.setupStyle || '').toLowerCase() === String(opt || '').toLowerCase() ? 'selected' : '';
                    return `<option value="${opt || ''}" ${selected}>${opt || ''}</option>`;
                  }).join('');

                  const dfHydrate = window.__islaDateFormat;
                  const eventDateDisplay = dfHydrate ? dfHydrate.formatIsoToDdMmYyyy(item.eventDate || '') : (item.eventDate || '');
                  const minDateAttr = item.minDate || '';

                  wrap.innerHTML = `
                    <div class="isla-form-title">${item.title || 'Please share your event details'}</div>
                    <div class="isla-form-grid two-col">
                      <div class="isla-form-field"><label>Venue</label><select disabled aria-readonly="true" title="Venue"><option selected>${venueLabel}</option></select></div>
                      <div class="isla-form-field"><label>Room</label><select data-event-room-select>${roomOptsHtml}</select></div>
                    </div>
                    <div class="isla-form-grid two-col">
                      <div class="isla-form-field"><label>Event type</label><input type="text" value="${item.eventType || ''}" data-event-type /></div>
                      <div class="isla-form-field"><label>Attendee count</label><input type="number" min="1" step="1" value="${item.attendees || ''}" data-event-attendees /></div>
                      <div class="isla-form-field"><label>Date</label><input type="text" value="${eventDateDisplay}" placeholder="DD-MM-YYYY" inputmode="numeric" autocomplete="off" data-event-date data-min-date="${minDateAttr}" /></div>
                      <div class="isla-form-field" data-event-setup-wrap><label>Room setup style</label><select data-event-setup>${setupHtml}</select></div>
                    </div>
                    <div class="isla-inline-note">Schedule</div>
                    <div class="isla-form-grid two-col">
                      <div class="isla-form-field"><label>Setup</label><input type="time" value="${schedule.setup || '07:00'}" step="1800" data-event-setup-time /></div>
                      <div class="isla-form-field"><label>Rehearsal</label><input type="time" value="${schedule.rehearsal || '09:30'}" step="1800" data-event-rehearsal-time /></div>
                      <div class="isla-form-field"><label>Start</label><input type="time" value="${schedule.start || '10:00'}" step="1800" data-event-start-time /></div>
                      <div class="isla-form-field"><label>End</label><input type="time" value="${schedule.end || '16:00'}" step="1800" data-event-end-time /></div>
                    </div>
                    <div class="isla-form-actions">
                      <button type="button" class="isla-form-submit" data-event-submit>${item.submitLabel || 'Send event details'}</button>
                    </div>
                    <div class="isla-form-error" data-event-error style="display:none"></div>`;
                  holder.appendChild(wrap);
                  if (typeof window.initWizardForms === 'function') window.initWizardForms(wrap);
                }

                if (item.type === 'avExtrasForm') {
                  const wrap = document.createElement('div');
                  wrap.className = 'isla-form-card isla-av-extras-form';
                  wrap.setAttribute('data-av-extras-form', '');
                  wrap.setAttribute('data-event-start', item.eventStart || item.techStart || '10:00');
                  wrap.setAttribute('data-event-end', item.eventEnd || item.techEnd || '16:00');
                  wrap.innerHTML = `
                    <div class="isla-form-title">${item.title || 'Confirm AV extras'}</div>
                    <div class="isla-form-grid two-col">
                      <div class="isla-form-field"><label>Presenters (with slides)</label><input type="number" min="0" step="1" value="${item.presenters || 0}" data-av-presenters /></div>
                      <div class="isla-form-field"><label>Speakers (without slides)</label><input type="number" min="0" step="1" value="${item.speakers || 0}" data-av-speakers /></div>
                    </div>
                    <div class="isla-form-grid">
                      <label class="isla-form-checkbox"><input type="checkbox" data-av-clicker ${item.clicker ? 'checked' : ''} /> Wireless clicker</label>
                      <label class="isla-form-checkbox"><input type="checkbox" data-av-recording ${item.recording ? 'checked' : ''} /> Audio/video recording</label>
                    </div>
                    <div class="isla-inline-note">Technician coverage</div>
                    <div class="isla-form-tech-row">
                      <div class="isla-form-field"><label>Start</label><input type="time" step="1800" value="${item.techStart || item.eventStart || '10:00'}" data-av-tech-start /></div>
                      <div class="isla-form-field"><label>End</label><input type="time" step="1800" value="${item.techEnd || item.eventEnd || '16:00'}" data-av-tech-end /></div>
                    </div>
                    <div class="isla-form-actions">
                      <button type="button" class="isla-form-secondary" data-av-whole-duration>Whole event duration</button>
                      <button type="button" class="isla-form-submit" data-av-submit>${item.submitLabel || 'Send AV extras'}</button>
                    </div>
                    <div class="isla-form-error" data-av-error style="display:none"></div>`;
                  holder.appendChild(wrap);
                }

                // Submitted form read-only display
                if (item.type === 'submittedForm') {
                  const wrap = document.createElement('div');
                  wrap.className = 'isla-form-summary-card';
                  const items = item.items || [];
                  const itemsHtml = items.map(it => {
                    if (!it.value) return '';
                    return `<div class="isla-form-summary-item"><span class="isla-form-summary-label">${it.label || ''}</span><span class="isla-form-summary-value">${it.value}</span></div>`;
                  }).join('');
                  wrap.innerHTML = `
                    <div class="isla-form-summary-title">${item.title || 'Submitted'}</div>
                    <div class="isla-form-summary-grid">${itemsHtml}</div>`;
                  holder.appendChild(wrap);
                }
              });

              if (holder.children.length > 0) {
                node.insertAdjacentElement('afterend', holder);
                node.remove(); // hide raw JSON
              }
            });
            if (typeof window.initWizardForms === 'function') window.initWizardForms(root || messagesWrap);
          }

          // Form buttons (email, venue, etc.) use postChat in _Messages.cshtml — they must hydrate ui-json the same way as the main send box.
          window.hydrateUiBlocks = hydrateUiBlocks;

          function getCsrfToken() {
            const el = document.querySelector('input[name="__RequestVerificationToken"]');
            return el ? el.value : '';
          }

          window.__islaChatSendChain = Promise.resolve();
          window.__islaOutboundSendDepth = 0;

          function syncWizardSubmitButtonsToOutboundDepth() {
            const busy = (window.__islaOutboundSendDepth || 0) > 0;
            messagesWrap.querySelectorAll('button.isla-form-submit').forEach(function(b) {
              b.disabled = busy;
            });
          }

          function beginOutboundChatUi() {
            window.__islaOutboundSendDepth = (window.__islaOutboundSendDepth || 0) + 1;
            if (window.__islaOutboundSendDepth === 1) {
              addTypingBubble();
              sendBtn.disabled = true;
              if (input) input.disabled = true;
            }
            syncWizardSubmitButtonsToOutboundDepth();
          }

          function endOutboundChatUi() {
            window.__islaOutboundSendDepth = Math.max(0, (window.__islaOutboundSendDepth || 1) - 1);
            syncWizardSubmitButtonsToOutboundDepth();
            if (window.__islaOutboundSendDepth === 0) {
              removeTypingBubble();
              sendBtn.disabled = false;
              if (input) input.disabled = false;
              input.focus();
            }
          }

          window.queueChatSend = function(work) {
            beginOutboundChatUi();
            const p = window.__islaChatSendChain
              .then(function() { return work(); })
              .finally(function() { endOutboundChatUi(); });
            window.__islaChatSendChain = p.catch(function() { return undefined; });
            return p;
          };

          async function runChatSendInternal(text, options) {
            options = options || {};
            const busyEl = options.busyEl;
            const helpers = window.__islaChatHelpers || {};
            let sendReqTimeout = null;
            let continueReqTimeout = null;

            try {
              const token = getCsrfToken();
              sendReqTimeout = createRequestTimeout();
              const res = await fetch('@Url.Action("SendPartial", "Chat")', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                  'RequestVerificationToken': token
                },
                body: new URLSearchParams({ text }),
                signal: sendReqTimeout.signal
              });
              sendReqTimeout.clear();
              sendReqTimeout = null;
              if (!res.ok) throw new Error('Request failed');
              const textRes = await res.text();

              let parsed = null;
              try { parsed = JSON.parse(textRes); } catch (_) {}

              if (parsed && parsed.success === false && parsed.error) {
                if (busyEl && busyEl.isConnected) {
                  if (helpers.clearBusy) helpers.clearBusy(busyEl);
                  if (helpers.clearThinkingNear) helpers.clearThinkingNear(busyEl);
                }
                const emailForm = busyEl && busyEl.closest && busyEl.closest('[data-email-form]');
                if (emailForm && helpers.showFormError) {
                  helpers.showFormError(emailForm.querySelector('[data-email-error]'), parsed.error);
                } else {
                  alert(parsed.error);
                }
                return;
              }

              let html = textRes;
              let continueNeeded = false;
              if (parsed && typeof parsed === 'object') {
                const fragment = parsed.html != null ? parsed.html : parsed.Html;
                if (parsed.continueNeeded && fragment && typeof fragment === 'string') {
                  html = fragment;
                  continueNeeded = true;
                } else if (parsed.success && fragment && typeof fragment === 'string') {
                  // Server returned JSON {success:true, html:"..."} without continueNeeded
                  html = fragment;
                }
              }

              if (!html || typeof html !== 'string' || !html.trim()) {
                throw new Error('Empty response');
              }

              messagesWrap.innerHTML = html;
              hydrateUiBlocks(messagesWrap);
              syncWizardSubmitButtonsToOutboundDepth();
              ensureOutboundTypingVisible();
              updateProgressBar();
              scrollToBottom();

              if (continueNeeded) {
                continueReqTimeout = createRequestTimeout();
                const contRes = await fetch('@Url.Action("ContinuePartial", "Chat")', {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'RequestVerificationToken': getCsrfToken()
                  },
                  body: new URLSearchParams({ __RequestVerificationToken: getCsrfToken() }),
                  signal: continueReqTimeout.signal
                });
                continueReqTimeout.clear();
                continueReqTimeout = null;
                if (!contRes.ok) throw new Error('Continue failed');
                const fullHtml = await contRes.text();
                if (!fullHtml || typeof fullHtml !== 'string' || !fullHtml.trim()) {
                  throw new Error('Empty continue response');
                }
                messagesWrap.innerHTML = fullHtml;
                hydrateUiBlocks(messagesWrap);
                syncWizardSubmitButtonsToOutboundDepth();
                ensureOutboundTypingVisible();
                updateProgressBar();
                scrollToBottom();
              }
            } catch (err) {
              console.error(err);
              appendAssistantFallbackMessage(fallbackMessageForError(err));
            } finally {
              if (sendReqTimeout) sendReqTimeout.clear();
              if (continueReqTimeout) continueReqTimeout.clear();
              if (busyEl && busyEl.isConnected) {
                if (helpers.clearBusy) helpers.clearBusy(busyEl);
                if (helpers.clearThinkingNear) helpers.clearThinkingNear(busyEl);
              }
            }
          }

          window.__islaVenueConfirmQueuedOrBusy = false;
          window.runChatSend = function(text, opts) {
            const t = (text || '').trim();
            const isVenueConfirm = /^VenueConfirm:/i.test(t);
            if (isVenueConfirm && window.__islaVenueConfirmQueuedOrBusy) {
              return Promise.resolve();
            }
            if (isVenueConfirm) window.__islaVenueConfirmQueuedOrBusy = true;
            const p = window.queueChatSend(function() { return runChatSendInternal(text, opts || {}); });
            p.finally(function() {
              if (isVenueConfirm) window.__islaVenueConfirmQueuedOrBusy = false;
            });
            return p;
          };

          // Send a UI selection as a compact user message to keep the flow going
          async function sendSelection(kind, value) {
            const text = `[UI_SELECT] ${JSON.stringify({ kind, value })}`;
            await window.runChatSend(text, {});
          }
          window.sendSelection = sendSelection; // expose for gallery buttons

          // Initial hydrate + scroll (in case agent already returned UI blocks)
          hydrateUiBlocks(messagesWrap);
          updateProgressBar();
          scrollToBottom();

          function isActiveForm(formEl) {
            if (!formEl) return false;
            if (formEl.getAttribute('data-form-submitted') === '1') return false;
            return formEl.offsetParent !== null;
          }

          /** Base AV stays on screen after confirm; user can edit and re-send. */
          function isBaseAvFormVisible(formEl) {
            return isActiveForm(formEl);
          }

          /** Venue confirm card stays editable after Confirmed; merge into send like Base AV. */
          function isVenueConfirmFormVisible(formEl) {
            return isActiveForm(formEl);
          }

          function validateVenueConfirmForSend() {
            const form = messagesWrap.querySelector('[data-venue-confirm-form]');
            if (!isVenueConfirmFormVisible(form)) return true;
            const df = window.__islaDateFormat;
            const err = form.querySelector('[data-vc-error]');
            const showErr = (msg) => {
              if (window.__islaChatHelpers && window.__islaChatHelpers.showFormError) window.__islaChatHelpers.showFormError(err, msg);
              else if (err) { err.textContent = msg || ''; err.style.display = msg ? 'block' : 'none'; }
            };
            const venue = (form.querySelector('[data-vc-venue-select] option:checked')?.textContent || '').trim();
            const room = (form.querySelector('[data-vc-room-select]')?.value || '').trim();
            const startRaw = (form.querySelector('[data-vc-start-date]')?.value || '').trim();
            const endRaw = (form.querySelector('[data-vc-end-date]')?.value || '').trim() || startRaw;
            const attendees = (form.querySelector('[data-vc-attendees]')?.value || '').trim();
            if (!venue || !room || !startRaw || !attendees) {
              showErr('');
              return true;
            }
            if (!df) {
              showErr('Date helpers failed to load. Please refresh the page.');
              return false;
            }
            const startIso = df.parseDdMmYyyyToIso(startRaw);
            const endIso = df.parseDdMmYyyyToIso(endRaw);
            if (!startIso || !endIso) {
              showErr('Please enter start and end dates as DD-MM-YYYY.');
              return false;
            }
            const minD = (form.getAttribute('data-vc-min-date') || '').trim();
            if (minD && (df.compareIso(startIso, minD) < 0 || df.compareIso(endIso, minD) < 0)) {
              showErr('Event dates must be on or after the minimum date allowed.');
              return false;
            }
            showErr('');
            return true;
          }

          function buildVenueConfirmPayload(userText) {
            const form = messagesWrap.querySelector('[data-venue-confirm-form]');
            if (!isVenueConfirmFormVisible(form)) return '';
            const venue = (form.querySelector('[data-vc-venue-select] option:checked')?.textContent || '').trim();
            const room = (form.querySelector('[data-vc-room-select]')?.value || '').trim();
            const startRaw = (form.querySelector('[data-vc-start-date]')?.value || '').trim();
            const endRaw = (form.querySelector('[data-vc-end-date]')?.value || '').trim() || startRaw;
            const attendees = (form.querySelector('[data-vc-attendees]')?.value || '').trim();
            if (!venue || !room || !startRaw || !attendees) return '';
            const df = window.__islaDateFormat;
            if (!df) return '';
            const startIso = df.parseDdMmYyyyToIso(startRaw);
            const endIso = df.parseDdMmYyyyToIso(endRaw);
            if (!startIso || !endIso) return '';
            const minD = (form.getAttribute('data-vc-min-date') || '').trim();
            if (minD && (df.compareIso(startIso, minD) < 0 || df.compareIso(endIso, minD) < 0)) return '';
            const enc = (v) => encodeURIComponent(v || '');
            return `VenueConfirm: venue=${enc(venue)}; room=${enc(room)}; startDate=${enc(startIso)}; endDate=${enc(endIso)}; attendees=${enc(attendees)}; userMessage=${enc(userText)}`;
          }

          function buildBaseAvPayload(userText) {
            const forms = Array.from(messagesWrap.querySelectorAll('[data-base-av-form]')).filter(isBaseAvFormVisible);
            const form = forms.length ? forms[forms.length - 1] : null;
            if (!form) return '';
            const combinedPS = form.querySelector('[data-ba-projscreen]');
            const pl = (form.querySelector('[data-ba-placement]')?.value || '').trim();
            // Ballroom mode: no checkboxes exist — derive flags from placement selection
            const isBallroomMode = !combinedPS && !form.querySelector('[data-ba-proj]') && !form.querySelector('[data-ba-spk]') && form.querySelector('[data-ba-placement]');
            let bp, bs, bsp;
            if (isBallroomMode) {
              const noProj = pl.toLowerCase() === 'none';
              bp = noProj ? 'no' : 'yes';
              bs = noProj ? 'no' : 'yes';
              bsp = 'yes'; // ballroom always has speakers available
            } else {
              bp = combinedPS ? (combinedPS.checked ? 'yes' : 'no') : (form.querySelector('[data-ba-proj]')?.checked ? 'yes' : 'no');
              bs = combinedPS ? (combinedPS.checked ? 'yes' : 'no') : (form.querySelector('[data-ba-screen]')?.checked ? 'yes' : 'no');
              bsp = form.querySelector('[data-ba-spk]')?.checked ? 'yes' : 'no';
            }
            const pr = (form.querySelector('[data-ba-presenters]')?.value || '0').trim();
            const fc = form.querySelector('[data-ba-flip]:checked')?.value || 'no';
            const lapChecked = form.querySelector('[data-ba-laptop-mode]:checked');
            const lm = lapChecked ? lapChecked.value : 'none';
            const lq = (form.querySelector('[data-ba-laptop-qty]')?.value || '0').trim();
            const ad = form.querySelector('[data-ba-adapter]:checked')?.value || 'no';
            const enc = (v) => encodeURIComponent(v || '');
            return `BaseAv: builtInProjector=${bp}; builtInScreen=${bs}; builtInSpeakers=${bsp}; projectorPlacement=${enc(pl)}; presenters=${enc(pr)}; flipchart=${enc(fc)}; laptopMode=${enc(lm)}; laptopQty=${enc(lq)}; adapterOwnLaptops=${enc(ad)}; userMessage=${enc(userText)}`;
          }

          function buildStructuredSendText(userText) {
            return buildVenueConfirmPayload(userText)
              || buildBaseAvPayload(userText)
              || userText;
          }

          // ----- SEND -----
          sendForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const userText = (input.value || '').trim();
            if (!userText) return;
            if (!validateVenueConfirmForSend()) return;
            const payloadText = buildStructuredSendText(userText);

            const userMessageDiv = document.createElement('div');
            userMessageDiv.className = 'chat-message message-sent';
            userMessageDiv.innerHTML = `
              <div class="chat-message-box">
                <div class="chat-message-body">
                  <div class="chat-text">${escapeHtml(userText)}</div>
                </div>
              </div>`;
            messagesWrap.appendChild(userMessageDiv);
            input.value = '';
            scrollToBottom();

            await window.runChatSend(payloadText, { useTypingBubble: true });
          });

          // ----- RESET (New Thread) -----
          if (resetForm) {
            resetForm.addEventListener('submit', async (e) => {
              e.preventDefault();
              try {
                const res = await fetch('@Url.Action("ResetPartial", "Chat")', {
                  method: 'POST',
                  headers: { 'RequestVerificationToken': resetToken }
                });
                if (!res.ok) throw new Error('Reset failed');
                const html = await res.text();
                messagesWrap.innerHTML = html;
                hydrateUiBlocks(messagesWrap);
                updateProgressBar();
                scrollToBottom();
                input.focus();
              } catch (err) {
                console.error(err);
                alert(err.message || 'Failed to reset');
              }
            });
          }

          // ----- EDIT QUOTE (re-open all forms) -----
          messagesWrap.addEventListener('click', async function(e) {
            const btn = e.target.closest('.isla-quote-edit-btn');
            if (!btn) return;
            btn.disabled = true;
            if (input) { input.placeholder = 'Loading...'; input.disabled = true; }
            try {
              const res = await fetch('@Url.Action("EditQuotePartial", "Chat")', {
                method: 'POST',
                headers: { 'RequestVerificationToken': getCsrfToken() }
              });
              if (!res.ok) throw new Error('Edit failed');
              const html = await res.text();
              messagesWrap.innerHTML = html;
              hydrateUiBlocks(messagesWrap);
              updateProgressBar();
              scrollToBottom();
              if (input) { input.placeholder = 'Type your message...'; input.disabled = false; }
              input.focus();
            } catch (err) {
              console.error(err);
              btn.disabled = false;
              if (input) { input.placeholder = 'Type your message...'; input.disabled = false; }
            }
          });

          // ----- DEV MODE: Conversation Replay -----
          const startReplayBtn = document.getElementById('startReplayBtn');
          const nextReplayBtn = document.getElementById('nextReplayBtn');
          const replayStatus = document.getElementById('replayStatus');
          const startAutoTestBtn = document.getElementById('startAutoTestBtn');
          const testScenarioModal = document.getElementById('testScenarioModal');
          const closeModalBtn = document.getElementById('closeModalBtn');
          const scenarioBtns = document.querySelectorAll('.scenario-btn');

          // Show modal when clicking Test button
          if (startReplayBtn) {
            startReplayBtn.addEventListener('click', () => {
              testScenarioModal.style.display = 'flex';
            });
          }

          // Close modal
          if (closeModalBtn) {
            closeModalBtn.addEventListener('click', () => {
              testScenarioModal.style.display = 'none';
            });
          }

          // Close modal when clicking outside
          if (testScenarioModal) {
            testScenarioModal.addEventListener('click', (e) => {
              if (e.target === testScenarioModal) {
                testScenarioModal.style.display = 'none';
              }
            });
          }

          // Handle scenario selection (scripted replay vs AI auto-test)
          scenarioBtns.forEach(btn => {
            btn.addEventListener('click', async () => {
              const scenario = btn.dataset.scenario;
              const autoTestScenario = btn.dataset.autotest;
              testScenarioModal.style.display = 'none';

              if (autoTestScenario !== undefined) {
                // AI Auto-Test flow
                try {
                  const res = await fetch('@Url.Action("StartAutoTest", "Chat")', {
                    method: 'POST',
                    headers: {
                      'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                      'RequestVerificationToken': sendToken
                    },
                    body: new URLSearchParams({ scenario: autoTestScenario })
                  });
                  const data = await res.json();
                  if (!data.success) throw new Error(data.error || 'Failed to start auto-test');
                  
                  // Reset chat messages UI for new test
                  messagesWrap.innerHTML = '';
                  
                  const panel = document.getElementById('autoTestPanel');
                  const statusEl = document.getElementById('autoTestStatus');
                  statusEl.textContent = `${data.personaName}`;
                  panel.style.display = 'block';
                  window.__autoTestRunning = true;
                  window.__autoTestPaused = false;
                  window.__autoTestAbort = false;
                  runAutoTestLoop();
                } catch (err) {
                  console.error(err);
                  alert(err.message || 'Failed to start AI auto-test');
                }
                return;
              }

              // Scripted replay flow
              try {
                startReplayBtn.disabled = true;
                startReplayBtn.textContent = 'Starting...';

                const res = await fetch('@Url.Action("StartConversationReplay", "Chat")', {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'RequestVerificationToken': sendToken
                  },
                  body: new URLSearchParams({ scenario })
                });

                const data = await res.json();
                if (data.success) {
                  startReplayBtn.style.display = 'none';
                  nextReplayBtn.style.display = 'inline-block';
                  replayStatus.style.display = 'inline';
                  replayStatus.textContent = `${data.scenarioName}: ${data.messageCount} messages`;
                  nextReplayBtn.disabled = false;
                } else {
                  throw new Error(data.error || 'Failed to start replay');
                }
              } catch (err) {
                console.error(err);
                alert(err.message || 'Failed to start conversation replay');
                startReplayBtn.disabled = false;
                startReplayBtn.innerHTML = '<i class="ph ph-play"></i> Test';
              }
            });
          });

          // ----- AI Auto-Test loop and controls -----
          const autoTestPanel = document.getElementById('autoTestPanel');
          const autoTestStatus = document.getElementById('autoTestStatus');
          const autoTestStep = document.getElementById('autoTestStep');
          const autoTestGenerated = document.getElementById('autoTestGenerated');
          const autoTestPauseBtn = document.getElementById('autoTestPauseBtn');
          const autoTestStopBtn = document.getElementById('autoTestStopBtn');
          const autoTestDelay = document.getElementById('autoTestDelay');
          const maxSteps = 30;

          function updateMilestones(m) {
            if (!m) return;
            const set = (id, done) => {
              const el = document.getElementById(id);
              if (el) { el.className = 'atp-badge ' + (done ? 'on' : 'off'); }
            };
            set('m-name', m.nameProvided);
            set('m-status', m.customerStatusProvided);
            set('m-org', m.organizationProvided);
            set('m-contact', m.contactInfoProvided);
            set('m-event', m.eventDetailsProvided);
            set('m-equipment', m.equipmentDiscussed);
            set('m-schedule', m.scheduleConfirmed);
            set('m-summary', m.quoteSummaryShown);
            set('m-quote', m.quoteGenerated);
            set('m-confirmed', m.quoteConfirmed);
          }

          let autoTestAbortCtrl = null;

          async function runAutoTestLoop() {
            while (window.__autoTestRunning && !window.__autoTestAbort) {
              while (window.__autoTestPaused && !window.__autoTestAbort) {
                await new Promise(r => setTimeout(r, 300));
              }
              if (window.__autoTestAbort) break;
              autoTestAbortCtrl = new AbortController();
              try {
                const res = await fetch('@Url.Action("RunAutoTestStep", "Chat")', {
                  method: 'POST',
                  headers: { 'RequestVerificationToken': sendToken },
                  signal: autoTestAbortCtrl.signal
                });
                const data = await res.json();
                if (!data.success) {
                  autoTestStatus.textContent = 'Error: ' + (data.error || 'Unknown');
                  autoTestStatus.style.color = '#d32f2f';
                  break;
                }
                if (data.html) {
                  messagesWrap.innerHTML = data.html;
                  hydrateUiBlocks(messagesWrap);
                  updateProgressBar();
                  scrollToBottom();
                }
                if (data.generatedMessage) {
                  autoTestGenerated.textContent = 'Customer said: ' + data.generatedMessage;
                }
                autoTestStep.textContent = 'Step ' + (data.stepNumber || 0) + '/' + maxSteps;
                if (data.milestones) updateMilestones(data.milestones);
                if (data.isComplete) {
                  autoTestStatus.textContent = 'Complete: ' + (data.completionState?.completionReason || 'Done');
                  autoTestStatus.style.color = '#2e7d32';
                  window.__autoTestRunning = false;
                  break;
                }
                const delay = parseInt(autoTestDelay?.value || 3000, 10) || 3000;
                await new Promise(r => setTimeout(r, Math.max(500, delay)));
              } catch (err) {
                if (err.name === 'AbortError') break;
                console.error(err);
                autoTestStatus.textContent = 'Error: ' + err.message;
                window.__autoTestRunning = false;
                break;
              }
            }
            autoTestAbortCtrl = null;
            if (window.__autoTestAbort) {
              autoTestStatus.textContent = 'Stopped';
            }
          }

          if (startAutoTestBtn) {
            startAutoTestBtn.addEventListener('click', () => {
              testScenarioModal.style.display = 'flex';
            });
          }
          if (autoTestPauseBtn) {
            autoTestPauseBtn.addEventListener('click', () => {
              window.__autoTestPaused = !window.__autoTestPaused;
              autoTestPauseBtn.textContent = window.__autoTestPaused ? 'Resume' : 'Pause';
            });
          }
          if (autoTestStopBtn) {
            autoTestStopBtn.addEventListener('click', async () => {
              window.__autoTestAbort = true;
              window.__autoTestRunning = false;
              autoTestStopBtn.disabled = true;
              if (autoTestAbortCtrl) autoTestAbortCtrl.abort();
              try {
                await fetch('@Url.Action("StopAutoTest", "Chat")', {
                  method: 'POST',
                  headers: { 'RequestVerificationToken': sendToken }
                });
              } catch (e) { /* ignore */ }
            });
          }

          if (nextReplayBtn) {
            nextReplayBtn.addEventListener('click', async () => {
              try {
                nextReplayBtn.disabled = true;
                nextReplayBtn.innerHTML = '<i class="ph ph-spinner ph-spin"></i> Sending...';

                const res = await fetch('@Url.Action("GetNextReplayMessage", "Chat")', {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'RequestVerificationToken': sendToken
                  }
                });

                const data = await res.json();
                if (data.success) {
                  // Auto-fill the input with the next message
                  input.value = data.message;
                  replayStatus.textContent = data.completed ? 'Completed!' : `${data.remaining} messages remaining`;

                  if (data.completed) {
                    nextReplayBtn.style.display = 'none';
                    startReplayBtn.style.display = 'inline-block';
                    startReplayBtn.disabled = false;
                    startReplayBtn.innerHTML = '<i class="ph ph-play"></i> Test';
                    replayStatus.style.display = 'none';
                  } else {
                    nextReplayBtn.disabled = false;
                    nextReplayBtn.innerHTML = '<i class="ph ph-fast-forward"></i> Next';
                  }
                } else {
                  if (data.error === 'Replay completed') {
                    nextReplayBtn.style.display = 'none';
                    startReplayBtn.style.display = 'inline-block';
                    startReplayBtn.disabled = false;
                    startReplayBtn.innerHTML = '<i class="ph ph-play"></i> Test';
                    replayStatus.style.display = 'none';
                  } else {
                    throw new Error(data.error || 'Failed to get next message');
                  }
                }
              } catch (err) {
                console.error(err);
                alert(err.message || 'Failed to get next replay message');
                nextReplayBtn.disabled = false;
                nextReplayBtn.innerHTML = '<i class="ph ph-fast-forward"></i> Next';
              }
            });
          }
        })();
    </script>
}
