@using MicrohireAgentChat.Services
@model IEnumerable<DisplayMessage>

@{
    ViewData["Title"] = "Isla – Microhire";
}

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet" />

<!-- Phosphor icons (bundle) -->
@* <link rel="preconnect" href="https://unpkg.com" crossorigin />
<link rel="stylesheet" href="https://unpkg.com/%40phosphor-icons/web@2.1.1/src/index.css" />
 *@
<!-- Your theme -->
<link rel="stylesheet" href="~/css/style.css" />
<link rel="stylesheet" href="~/css/style_fill.css" />
<link rel="stylesheet" href="~/css/style_regular.css" />

<!-- Tiny inline styles only for typing bubble (using @@keyframes to avoid Razor errors) -->
<style>
    .typing-bubble .chat-message-body { padding-right: 12px; }
    .typing-ellipsis {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 22px;
      line-height: 1;
      padding: 10px 12px;
      background: #f7f8fc;
      border: 1px solid #e6e8ef;
      border-radius: 12px;
    }
    .typing-ellipsis span {
      display: inline-block;
      width: .45em;
      text-align: center;
      opacity: .25;
      animation: typing-pulse 1.1s ease-in-out infinite;
    }
    .typing-ellipsis span:nth-child(2) { animation-delay: .15s; }
    .typing-ellipsis span:nth-child(3) { animation-delay: .30s; }
    @@keyframes typing-pulse {
      0%, 80%, 100% { transform: translateY(0); opacity: .25; }
      40%           { transform: translateY(-4px); opacity: 1; }
    }
</style>

<div class="chat-box-main">
    <div class="chat-box-header">
        <!-- adjust classes (first-step-active/second-step-active) as your flow progresses -->
        <div class="chat-box-progress @ViewData["ProgressStep"]"></div>
        <div class="chat-box-progress-titles">
            <span>Venue</span>
            <span>Services</span>
            <span>Review</span>
            <span>Quote</span>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(ViewData["ExistingQuoteUrl"] as string))
    {
        <div class="alert alert-success border-0 rounded-0 mb-0 py-2 px-3" style="background: #d4edda; border-bottom: 1px solid #c3e6cb;">
            <div class="d-flex align-items-center">
                <i class="ph ph-check-circle text-success me-2"></i>
                <div class="flex-grow-1">
                    <strong>Quote Ready!</strong> Your professional quote has been generated and is available for download.
                </div>
                <a href="@ViewData["ExistingQuoteUrl"]" target="_blank" class="btn btn-success btn-sm ms-3">
                    <i class="ph ph-download me-1"></i> Download PDF
                </a>
            </div>
        </div>
    }

    <div class="chat-box-body">
        <div id="messagesWrap" class="chat-box-wrap">
            @await Html.PartialAsync("_Messages", Model)
        </div>

        <div class="chat-box-type">
            <form id="sendForm" asp-action="Send" method="post" class="w-100">
                @Html.AntiForgeryToken()
                <input id="textInput" name="text" type="text" placeholder="Type your message..." autocomplete="off" />
            </form>

            <button id="sendBtn" type="submit" form="sendForm" title="Send">
                <i class="ph ph-caret-right"></i>
            </button>

            @{
                <button id="startReplayBtn" type="button" class="btn btn-outline-primary ms-2" title="Start Test Conversation">
                    <i class="ph ph-play"></i> Test
                </button>

                <button id="nextReplayBtn" type="button" class="btn btn-outline-secondary ms-1" title="Send Next Test Message" style="display:none">
                    <i class="ph ph-fast-forward"></i> Next
                </button>

                <span id="replayStatus" class="ms-2 text-muted" style="display:none"></span>
            }

            <form id="resetForm" asp-action="Reset" method="post" class="ms-2">
                @Html.AntiForgeryToken()
                <button class="btn btn-link text-decoration-none" type="submit" title="Start New Conversation">
                    <i class="ph ph-plus-circle"></i> New Quote
                </button>
            </form>
        </div>
    </div>
</div>

<!-- Test Scenario Selection Modal -->
<div id="testScenarioModal" class="modal-overlay" style="display: none;">
    <div class="modal-content">
        <div class="modal-header">
            <h3>Select Test Scenario</h3>
            <button type="button" class="modal-close" id="closeModalBtn">&times;</button>
        </div>
        <div class="modal-body">
            <div class="scenario-category">
                <h4>🐛 Bug Reproduction Tests</h4>
                <p class="category-desc">Test scenarios that reproduce reported bugs</p>
                <div class="scenario-list">
                    <button class="scenario-btn bug-scenario" data-scenario="ai_stops_responding">
                        <span class="scenario-icon">⚠️</span>
                        <span class="scenario-info">
                            <strong>AI Stops Responding</strong>
                            <small>Reproduces bug where AI stops after time picker confirmation</small>
                        </span>
                    </button>
                    <button class="scenario-btn bug-scenario" data-scenario="time_picker_validation">
                        <span class="scenario-icon">⏰</span>
                        <span class="scenario-info">
                            <strong>Time Picker Validation</strong>
                            <small>Tests time picker edge cases and validation</small>
                        </span>
                    </button>
                </div>
            </div>
            
            <div class="scenario-category">
                <h4>📋 Standard Test Flows</h4>
                <p class="category-desc">General conversation flow tests with randomized data</p>
                <div class="scenario-list">
                    <button class="scenario-btn" data-scenario="random">
                        <span class="scenario-icon">🎲</span>
                        <span class="scenario-info">
                            <strong>Random Scenario</strong>
                            <small>Randomly selects from all standard scenarios</small>
                        </span>
                    </button>
                    <button class="scenario-btn" data-scenario="small_event">
                        <span class="scenario-icon">👥</span>
                        <span class="scenario-info">
                            <strong>Small Event</strong>
                            <small>15-25 attendees, boardroom meeting</small>
                        </span>
                    </button>
                    <button class="scenario-btn" data-scenario="large_conference">
                        <span class="scenario-icon">🎪</span>
                        <span class="scenario-info">
                            <strong>Large Conference</strong>
                            <small>300-500 attendees, major event</small>
                        </span>
                    </button>
                    <button class="scenario-btn" data-scenario="social_event">
                        <span class="scenario-icon">🎉</span>
                        <span class="scenario-info">
                            <strong>Social/Gala Event</strong>
                            <small>Dinner, gala, or social gathering</small>
                        </span>
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: rgba(0, 0, 0, 0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 9999;
    }
    .modal-content {
        background: white;
        border-radius: 12px;
        max-width: 500px;
        width: 90%;
        max-height: 80vh;
        overflow-y: auto;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    }
    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 20px;
        border-bottom: 1px solid #e6e8ef;
    }
    .modal-header h3 {
        margin: 0;
        font-size: 18px;
        font-weight: 600;
    }
    .modal-close {
        background: none;
        border: none;
        font-size: 24px;
        cursor: pointer;
        color: #666;
        padding: 0;
        line-height: 1;
    }
    .modal-close:hover { color: #333; }
    .modal-body {
        padding: 16px 20px;
    }
    .scenario-category {
        margin-bottom: 20px;
    }
    .scenario-category h4 {
        margin: 0 0 4px 0;
        font-size: 14px;
        font-weight: 600;
        color: #333;
    }
    .category-desc {
        margin: 0 0 12px 0;
        font-size: 12px;
        color: #666;
    }
    .scenario-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .scenario-btn {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        background: #f7f8fc;
        border: 1px solid #e6e8ef;
        border-radius: 8px;
        cursor: pointer;
        text-align: left;
        transition: all 0.2s;
    }
    .scenario-btn:hover {
        background: #eef0f7;
        border-color: #d0d4e4;
    }
    .scenario-btn.bug-scenario {
        background: #fff5f5;
        border-color: #fecaca;
    }
    .scenario-btn.bug-scenario:hover {
        background: #fee2e2;
        border-color: #f87171;
    }
    .scenario-icon {
        font-size: 24px;
        flex-shrink: 0;
    }
    .scenario-info {
        display: flex;
        flex-direction: column;
        gap: 2px;
    }
    .scenario-info strong {
        font-size: 14px;
        font-weight: 600;
        color: #333;
    }
    .scenario-info small {
        font-size: 12px;
        color: #666;
    }
</style>

@section Scripts {
    <script>
        (() => {
          const messagesWrap = document.getElementById('messagesWrap');
          const sendForm     = document.getElementById('sendForm');
          const resetForm    = document.getElementById('resetForm');
          const input        = document.getElementById('textInput');
          const sendBtn      = document.getElementById('sendBtn');

          const sendToken  = sendForm.querySelector('input[name="__RequestVerificationToken"]').value;
          const resetToken = resetForm.querySelector('input[name="__RequestVerificationToken"]').value;

          function scrollToBottom() { messagesWrap.scrollTop = messagesWrap.scrollHeight; }

          // ----- Typing bubble -----
          function addTypingBubble() {
            if (document.getElementById('typing-bubble')) return;
            const wrap = document.createElement('div');
            wrap.id = 'typing-bubble';
            wrap.className = 'chat-message message-recived typing-bubble';
            wrap.innerHTML = `
              <div class="chat-message-box">
                <div class="chat-message-avatar">
                  <img src="${'@Url.Content("~/images/avatar.png")'}" alt="">
                </div>
                <div class="chat-message-body">
                  <div class="typing-ellipsis" aria-label="Isla is typing">
                    <span>.</span><span>.</span><span>.</span>
                  </div>
                </div>
              </div>`;
            messagesWrap.appendChild(wrap);
            scrollToBottom();
          }
          function removeTypingBubble() { const t = document.getElementById('typing-bubble'); if (t) t.remove(); }

          // ----- Hydrate agent UI JSON blocks (imageGallery, timePicker, multitime) -----
          function hydrateUiBlocks(root) {
            const nodes = (root || messagesWrap).querySelectorAll('script.ui-json[type="application/json"]');
            nodes.forEach(node => {
              let payload;
              try { payload = JSON.parse(node.textContent.trim() || "{}"); } catch { return; }
              const holder = document.createElement('div');

              // Handle both array format and object format for payload.ui
              const uiItems = Array.isArray(payload.ui) ? payload.ui : (payload.ui ? [payload.ui] : []);

              uiItems.forEach(item => {
                // image gallery -> cards from your theme
                if (item.type === 'imageGallery') {
                  const wrap = document.createElement('div');
                  wrap.className = 'message-card-wrap';
                  const urls = (item.data && (item.data.items || [])) || [];
                  urls.forEach(u => {
                    const card = document.createElement('div');
                    card.className = 'message-card-box';
                    const img  = document.createElement('img');
                    img.className = 'message-card-box-img';
                    img.src = u; img.alt = 'option';

                    const body = document.createElement('div');
                    body.className = 'message-card-box-content';
                    const h6 = document.createElement('h6'); h6.textContent = 'Tap to select';
                    const p  = document.createElement('p');  p.textContent  = '';
                    const btn = document.createElement('button'); btn.type = 'button'; btn.textContent = 'SELECT';
                    btn.onclick = () => sendSelection('image', u);

                    body.appendChild(h6); body.appendChild(p); body.appendChild(btn);
                    card.appendChild(img); card.appendChild(body);
                    wrap.appendChild(card);
                  });
                  holder.appendChild(wrap);
                }

                // time picker -> simple inputs inside cards
                if (item.type === 'timePicker') {
                  const wrap = document.createElement('div');
                  wrap.className = 'message-card-wrap';
                  const labels = (item.data && item.data.items) || [];
                  const times = {};
                  labels.forEach(label => {
                    const card = document.createElement('div');
                    card.className = 'message-card-box';
                    const body = document.createElement('div');
                    body.className = 'message-card-box-content';
                    const h6 = document.createElement('h6'); h6.textContent = `${label} Time`;
                    const inp = document.createElement('input'); inp.type = 'time';
                    inp.onchange = () => { times[label] = inp.value; };
                    const btn = document.createElement('button'); btn.type = 'button'; btn.textContent = 'SET';
                    btn.onclick = () => { times[label] = inp.value; };
                    body.appendChild(h6); body.appendChild(inp); body.appendChild(btn);
                    card.appendChild(body);
                    wrap.appendChild(card);
                  });
                  const done = document.createElement('button'); done.type = 'button'; done.textContent = 'Done';
                  done.style.marginTop = '8px'; done.onclick = () => sendSelection('times', times);
                  holder.appendChild(wrap);
                  holder.appendChild(done);
                }

                // multitime picker -> matches server-side structure
                if (item.type === 'multitime') {
                  const wrap = document.createElement('div');
                  wrap.className = 'isla-multitime';
                  const stepMinutes = item.stepMinutes || 15;
                  const dateIso = item.date || '';
                  wrap.setAttribute('data-step', stepMinutes);
                  wrap.setAttribute('data-date', dateIso);

                  // Title
                  if (item.title) {
                    const title = document.createElement('div');
                    title.className = 'isla-timepicker-title';
                    title.textContent = item.title;
                    wrap.appendChild(title);
                  }

                  // Grid container
                  const grid = document.createElement('div');
                  grid.className = 'isla-multitime-grid';

                  // Create picker inputs
                  const pickers = item.pickers || [];
                  pickers.forEach(picker => {
                    const itemDiv = document.createElement('div');
                    itemDiv.className = 'isla-mt-item';

                    const label = document.createElement('label');
                    label.textContent = picker.label || picker.name || '';
                    itemDiv.appendChild(label);

                    const input = document.createElement('input');
                    input.type = 'time';
                    input.className = 'mt-input';
                    input.setAttribute('data-name', picker.name || '');
                    input.step = stepMinutes * 60;
                    input.value = picker.default || picker.value || '09:00';
                    itemDiv.appendChild(input);

                    grid.appendChild(itemDiv);
                  });

                  wrap.appendChild(grid);

                  // Submit button
                  const submitBtn = document.createElement('button');
                  submitBtn.type = 'button';
                  submitBtn.className = 'btn-apply-multitime';
                  submitBtn.textContent = item.submitLabel || 'Submit';
                  wrap.appendChild(submitBtn);

                  holder.appendChild(wrap);
                }
              });

              if (holder.children.length > 0) {
                node.insertAdjacentElement('afterend', holder);
                node.remove(); // hide raw JSON
              }
            });
          }

          // Send a UI selection as a compact user message to keep the flow going
          async function sendSelection(kind, value) {
            const text = `[UI_SELECT] ${JSON.stringify({ kind, value })}`;
            sendBtn.disabled = true;
            addTypingBubble();

            try {
              const res = await fetch('@Url.Action("SendPartial", "Chat")', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                  'RequestVerificationToken': sendToken
                },
                body: new URLSearchParams({ text })
              });
              if (!res.ok) throw new Error('Request failed');
              const html = await res.text();
              messagesWrap.innerHTML = html;
              hydrateUiBlocks(messagesWrap);
              scrollToBottom();
            } catch (err) {
              console.error(err);
              alert(err.message || 'Failed to send selection');
            } finally {
              removeTypingBubble();
              sendBtn.disabled = false;
              input.focus();
            }
          }
          window.sendSelection = sendSelection; // expose for gallery buttons

          // Initial hydrate + scroll (in case agent already returned UI blocks)
          hydrateUiBlocks(messagesWrap);
          scrollToBottom();

          // ----- SEND -----
          sendForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const text = (input.value || '').trim();
            if (!text) return;

            // Immediately add user message to conversation
            const userMessageDiv = document.createElement('div');
            userMessageDiv.className = 'chat-message message-sent';
            userMessageDiv.innerHTML = `
              <div class="chat-message-box">
                <div class="chat-message-body">
                  <div class="chat-text">${text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')}</div>
                </div>
              </div>`;
            messagesWrap.appendChild(userMessageDiv);
            input.value = '';
            scrollToBottom();

            sendBtn.disabled = true;
            addTypingBubble();

            try {
              const res = await fetch('@Url.Action("SendPartial", "Chat")', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                  'RequestVerificationToken': sendToken
                },
                body: new URLSearchParams({ text })
              });
              if (!res.ok) throw new Error('Request failed');
              const html = await res.text();
              messagesWrap.innerHTML = html;
              hydrateUiBlocks(messagesWrap);
              scrollToBottom();
            } catch (err) {
              console.error(err);
              alert(err.message || 'Failed to send');
            } finally {
              removeTypingBubble();
              sendBtn.disabled = false;
              input.focus();
            }
          });

          // ----- RESET (New Thread) -----
          resetForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            try {
              const res = await fetch('@Url.Action("ResetPartial", "Chat")', {
                method: 'POST',
                headers: { 'RequestVerificationToken': resetToken }
              });
              if (!res.ok) throw new Error('Reset failed');
              const html = await res.text();
              messagesWrap.innerHTML = html;
              hydrateUiBlocks(messagesWrap);
              scrollToBottom();
              input.focus();
            } catch (err) {
              console.error(err);
              alert(err.message || 'Failed to reset');
            }
          });

          // ----- DEV MODE: Conversation Replay -----
          const startReplayBtn = document.getElementById('startReplayBtn');
          const nextReplayBtn = document.getElementById('nextReplayBtn');
          const replayStatus = document.getElementById('replayStatus');
          const testScenarioModal = document.getElementById('testScenarioModal');
          const closeModalBtn = document.getElementById('closeModalBtn');
          const scenarioBtns = document.querySelectorAll('.scenario-btn');

          // Show modal when clicking Test button
          if (startReplayBtn) {
            startReplayBtn.addEventListener('click', () => {
              testScenarioModal.style.display = 'flex';
            });
          }

          // Close modal
          if (closeModalBtn) {
            closeModalBtn.addEventListener('click', () => {
              testScenarioModal.style.display = 'none';
            });
          }

          // Close modal when clicking outside
          if (testScenarioModal) {
            testScenarioModal.addEventListener('click', (e) => {
              if (e.target === testScenarioModal) {
                testScenarioModal.style.display = 'none';
              }
            });
          }

          // Handle scenario selection
          scenarioBtns.forEach(btn => {
            btn.addEventListener('click', async () => {
              const scenario = btn.dataset.scenario;
              testScenarioModal.style.display = 'none';

              try {
                startReplayBtn.disabled = true;
                startReplayBtn.textContent = 'Starting...';

                const res = await fetch('@Url.Action("StartConversationReplay", "Chat")', {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'RequestVerificationToken': sendToken
                  },
                  body: new URLSearchParams({ scenario })
                });

                const data = await res.json();
                if (data.success) {
                  startReplayBtn.style.display = 'none';
                  nextReplayBtn.style.display = 'inline-block';
                  replayStatus.style.display = 'inline';
                  replayStatus.textContent = `${data.scenarioName}: ${data.messageCount} messages`;
                  nextReplayBtn.disabled = false;
                } else {
                  throw new Error(data.error || 'Failed to start replay');
                }
              } catch (err) {
                console.error(err);
                alert(err.message || 'Failed to start conversation replay');
                startReplayBtn.disabled = false;
                startReplayBtn.innerHTML = '<i class="ph ph-play"></i> Test';
              }
            });
          });

          if (nextReplayBtn) {
            nextReplayBtn.addEventListener('click', async () => {
              try {
                nextReplayBtn.disabled = true;
                nextReplayBtn.innerHTML = '<i class="ph ph-spinner ph-spin"></i> Sending...';

                const res = await fetch('@Url.Action("GetNextReplayMessage", "Chat")', {
                  method: 'POST',
                  headers: {
                    'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
                    'RequestVerificationToken': sendToken
                  }
                });

                const data = await res.json();
                if (data.success) {
                  // Auto-fill the input with the next message
                  input.value = data.message;
                  replayStatus.textContent = data.completed ? 'Completed!' : `${data.remaining} messages remaining`;

                  if (data.completed) {
                    nextReplayBtn.style.display = 'none';
                    startReplayBtn.style.display = 'inline-block';
                    startReplayBtn.disabled = false;
                    startReplayBtn.innerHTML = '<i class="ph ph-play"></i> Test';
                    replayStatus.style.display = 'none';
                  } else {
                    nextReplayBtn.disabled = false;
                    nextReplayBtn.innerHTML = '<i class="ph ph-fast-forward"></i> Next';
                  }
                } else {
                  if (data.error === 'Replay completed') {
                    nextReplayBtn.style.display = 'none';
                    startReplayBtn.style.display = 'inline-block';
                    startReplayBtn.disabled = false;
                    startReplayBtn.innerHTML = '<i class="ph ph-play"></i> Test';
                    replayStatus.style.display = 'none';
                  } else {
                    throw new Error(data.error || 'Failed to get next message');
                  }
                }
              } catch (err) {
                console.error(err);
                alert(err.message || 'Failed to get next replay message');
                nextReplayBtn.disabled = false;
                nextReplayBtn.innerHTML = '<i class="ph ph-fast-forward"></i> Next';
              }
            });
          }
        })();
    </script>
}
