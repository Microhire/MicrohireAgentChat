@using MicrohireAgentChat.Services
@using Markdig
@using System.Text.Json
@model IEnumerable<DisplayMessage>

@{
    var mdPipeline = new MarkdownPipelineBuilder()
        .UseAdvancedExtensions()
        .UseSoftlineBreakAsHardlineBreak()
        .Build();
}

<!-- Anti-forgery token for AJAX posts -->
<div style="display:none">
    @Html.AntiForgeryToken()
</div>

<style>
  /* minimal CTA styles (optional) */
  .isla-cta{margin-top:.75rem}
  .isla-cta-label{margin-bottom:.5rem;font-weight:600}
  .isla-cta-buttons{display:flex;gap:.5rem}
  .isla-cta-buttons .isla-quote-yes,.isla-cta-buttons .isla-quote-no{padding:.375rem .75rem;border-radius:.5rem;border:none;cursor:pointer}
  .isla-cta-buttons .isla-quote-yes{background:#c62828;color:#fff}
  .isla-cta-buttons .isla-quote-no{background:#eee;color:#333}
  .isla-busy{opacity:.7;pointer-events:none}
  .isla-spinner{display:inline-block;width:.9em;height:.9em;margin-left:.5em;border:.15em solid currentColor;border-right-color:transparent;border-radius:50%;animation:isla-spin .8s linear infinite}
  .isla-thinking{margin-top:.25rem;font-size:.9rem;color:#888}
</style>

@if (Model?.Any() != true)
{
    <div class="text-muted">No messages yet.</div>
}
else
{
    foreach (var m in Model)
    {
        var isAssistant = string.Equals(m.Role, "assistant", StringComparison.OrdinalIgnoreCase);
        var rowClass = isAssistant ? "message-recived" : "message-sent";

        var _rawAll = string.Join("\n", (m.Parts ?? new List<string>()).Select(p => p ?? string.Empty));
        var _rawAllLower = _rawAll.ToLowerInvariant();

        bool _looksLikeSummaryAsk = IsFinalSummaryAskBubble(_rawAllLower);
        bool _hasUiJson = _rawAllLower.Contains("\"ui\":")
                          || _rawAllLower.Contains("[[isla_gallery]]")
                          || _rawAllLower.Contains("{\"ui\":");
        bool _looksLikePicker = _rawAllLower.Contains("timepicker")
                                || _rawAllLower.Contains("multitime");

        <div class="chat-message @rowClass" data-role="@m.Role">
            <div class="chat-message-box">
                @if (isAssistant)
                {
                    <div class="chat-message-avatar">
                        <img src="~/images/avatar.png" alt="Isla" />
                    </div>
                }

                <div class="chat-message-body">
                    @{
                        foreach (var rawPart in (m.Parts ?? new List<string>()))
                        {
                            var part = rawPart ?? string.Empty;

                            // Ignore legacy <image:...> tokens
                            if (part.StartsWith("<image:", StringComparison.OrdinalIgnoreCase))
                                continue;

                            // -------------------- GALLERY BLOCKS (case-insensitive) --------------------
                            var galleryRe = new System.Text.RegularExpressions.Regex(
                                @"\[\[ISLA_GALLERY\]\](.*?)\[\[\/ISLA_GALLERY\]\]",
                                System.Text.RegularExpressions.RegexOptions.IgnoreCase | System.Text.RegularExpressions.RegexOptions.Singleline);

                            if (galleryRe.IsMatch(part))
                            {
                                int pos = 0;
                                foreach (System.Text.RegularExpressions.Match gm in galleryRe.Matches(part))
                                {
                                    // text before this gallery
                                    var before = part.Substring(pos, gm.Index - pos);
                                    if (!string.IsNullOrWhiteSpace(before))
                                    {
                                        var htmlBefore = Markdown.ToHtml(before, mdPipeline);
                                        <div class="chat-text">@Html.Raw(htmlBefore)</div>
                                    }

                                    var json = (gm.Groups[1].Value ?? string.Empty).Trim();
                                    try
                                    {
                                        var gallery = JsonSerializer.Deserialize<IslaGallery>(json, new JsonSerializerOptions
                                        {
                                            PropertyNameCaseInsensitive = true
                                        }) ?? new IslaGallery();

                                        <div class="isla-gallery">
                                            @if (!string.IsNullOrWhiteSpace(gallery.Room))
                                            {
                                                <div class="isla-gallery-title">@gallery.Room</div>
                                            }
                                            <div class="isla-gallery-grid">
                                                @foreach (var it in gallery.Items ?? Enumerable.Empty<IslaGalleryItem>())
                                                {
                                                    <button class="isla-card" type="button"
                                                            data-select='@Html.Raw(JsonSerializer.Serialize(it.Select ?? new { }))'>
                                                        <img src="@it.Url" alt="@it.Label" loading="lazy" />
                                                        <div class="isla-card-label">@it.Label</div>
                                                    </button>
                                                }
                                            </div>
                                        </div>
                                    }
                                    catch
                                    {
                                        <pre class="text-muted small">@json</pre>
                                    }

                                    pos = gm.Index + gm.Length;
                                }

                                // tail after last gallery
                                if (pos < part.Length)
                                {
                                    var tail = part.Substring(pos);
                                    if (!string.IsNullOrWhiteSpace(tail))
                                    {
                                        var htmlTail = Markdown.ToHtml(tail, mdPipeline);
                                        <div class="chat-text">@Html.Raw(htmlTail)</div>
                                    }
                                }

                                continue;
                            }

                            // --------------- INLINE UI (timepicker, multitime, etc.) ---------------
                            var uiIdx = part.IndexOf("{\"ui\":", StringComparison.Ordinal);
                            if (uiIdx >= 0)
                            {
                                var textBefore = part.Substring(0, uiIdx).TrimEnd();
                                var jsonBlock = part.Substring(uiIdx).Trim();

                                if (!string.IsNullOrWhiteSpace(textBefore))
                                {
                                    var htmlTB = Markdown.ToHtml(textBefore, mdPipeline);
                                    <div class="chat-text">@Html.Raw(htmlTB)</div>
                                }

                                try
                                {
                                    using var uiDoc = JsonDocument.Parse(jsonBlock);
                                    if (uiDoc.RootElement.TryGetProperty("ui", out var uiEl))
                                    {
                                        var type = (uiEl.TryGetProperty("type", out var t) ? t.GetString() : "") ?? "";
                                        var typeLower = type.ToLowerInvariant();

                                        // ---- single-interval timepicker ----
                                        if (typeLower == "isla.timepicker" || typeLower == "timepicker")
                                        {
                                            var title = uiEl.TryGetProperty("label", out var l) ? l.GetString()
                                                : uiEl.TryGetProperty("title", out var l2) ? l2.GetString()
                                                : "Select a time";

                                            var date = uiEl.TryGetProperty("date", out var d) ? d.GetString() : null;
                                            var defStart = uiEl.TryGetProperty("defaultStart", out var ds) ? ds.GetString() : "09:00";
                                            var defEnd = uiEl.TryGetProperty("defaultEnd", out var de) ? de.GetString() : "10:00";
                                            var stepMinutes = uiEl.TryGetProperty("stepMinutes", out var sm) ? sm.GetInt32() : 30;

                                            if (uiEl.TryGetProperty("options", out var opts) && opts.ValueKind == JsonValueKind.Array && opts.GetArrayLength() > 0)
                                            {
                                                <div class="isla-timechips">
                                                    <div class="isla-timepicker-title">@title</div>
                                                    <div class="isla-timechips-grid">
                                                        @foreach (var o in opts.EnumerateArray())
                                                        {
                                                            var labelOpt = o.TryGetProperty("label", out var ol) ? ol.GetString() : null;
                                                            var valueOpt = o.TryGetProperty("value", out var ov) ? ov.GetString() : labelOpt;
                                                            if (!string.IsNullOrWhiteSpace(labelOpt) && !string.IsNullOrWhiteSpace(valueOpt))
                                                            {
                                                                <button class="isla-chip" type="button" data-text="@valueOpt">@labelOpt</button>
                                                            }
                                                        }
                                                    </div>
                                                </div>
                                            }
                                            else
                                            {
                                                <div class="isla-timepicker" data-step="@stepMinutes" data-date="@date">
                                                    <div class="isla-timepicker-title">@title</div>
                                                    <div class="isla-timepicker-row">
                                                        <label>Start</label>
                                                        <input class="tp-start" type="time" step="@(stepMinutes * 60)" value="@defStart" />
                                                    </div>
                                                    <div class="isla-timepicker-row">
                                                        <label>End</label>
                                                        <input class="tp-end" type="time" step="@(stepMinutes * 60)" value="@defEnd" />
                                                    </div>
                                                    <button class="btn-apply-time" type="button">@((uiEl.TryGetProperty("submitLabel", out var sl) ? sl.GetString() : null) ?? "Submit")</button>
                                                </div>
                                            }
                                        }
                                        // ---- multi-time picker (setup / rehearsal / pack up) ----
                                        else if (typeLower == "multitime")
                                        {
                                            var title = uiEl.TryGetProperty("title", out var tTitle) ? tTitle.GetString() : "Select your schedule";
                                            var stepMinutes = uiEl.TryGetProperty("stepMinutes", out var sm) ? sm.GetInt32() : 15;
                                            var submit = uiEl.TryGetProperty("submitLabel", out var sLbl) ? sLbl.GetString() : "Submit";

                                            var pickers = new List<(string name, string label, string value)>();
                                            if (uiEl.TryGetProperty("pickers", out var pArr) && pArr.ValueKind == JsonValueKind.Array)
                                            {
                                                foreach (var p in pArr.EnumerateArray())
                                                {
                                                    var nm = p.TryGetProperty("name", out var pn) ? pn.GetString() : null;
                                                    var lb = p.TryGetProperty("label", out var pl) ? pl.GetString() : nm;
                                                    var dv = p.TryGetProperty("default", out var pd) ? pd.GetString() : "09:00";
                                                    if (!string.IsNullOrWhiteSpace(nm))
                                                        pickers.Add((nm!, lb ?? nm!, dv ?? "09:00"));
                                                }
                                            }

                                            <div class="isla-multitime" data-step="@stepMinutes">
                                                @if (!string.IsNullOrWhiteSpace(title))
                                                {
                                                    <div class="isla-timepicker-title">@title</div>
                                                }
                                                <div class="isla-multitime-grid">
                                                    @foreach (var p in pickers)
                                                    {
                                                        <div class="isla-mt-item">
                                                            <label>@p.label</label>
                                                            <input type="time" class="mt-input" data-name="@p.name" step="@(stepMinutes * 60)" value="@p.value" />
                                                        </div>
                                                    }
                                                </div>
                                                <button type="button" class="btn-apply-multitime">@submit</button>
                                            </div>
                                        }
                                        else
                                        {
                                            // Unknown UI type -> keep as data blob
                                            <script type="application/json" class="ui-json">@Html.Raw(jsonBlock)</script>
                                        }
                                    }
                                    else
                                    {
                                        <script type="application/json" class="ui-json">@Html.Raw(jsonBlock)</script>
                                    }
                                }
                                catch
                                {
                                    <script type="application/json" class="ui-json">@Html.Raw(jsonBlock)</script>
                                }

                                continue;
                            }

                            // Existing {"ui":...} without inline text
                            if (IsUiJson(part))
                            {
                                <script type="application/json" class="ui-json">@Html.Raw(part)</script>
                            }
                            else
                            {
                                var html = Markdown.ToHtml(part, mdPipeline);
                                <div class="chat-text">@Html.Raw(html)</div>
                            }
                        }

                        // ---------------- CTA: render only after an assistant summary ask ----------------
                        if (isAssistant && _looksLikeSummaryAsk && !_hasUiJson && !_looksLikePicker)
                        {
                            <div class="isla-cta" data-quote-controls>
                                <div class="isla-cta-label">Would you like me to create the quote now?</div>
                                <div class="isla-cta-buttons">
                                    <button type="button" class="isla-quote-yes">Yes, create quote</button>
                                    <button type="button" class="isla-quote-no">No, not yet</button>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    }
}

@functions{
    bool IsUiJson(string s){
        if (string.IsNullOrWhiteSpace(s)) return false;
        s=s.Trim(); if(!s.StartsWith("{")||!s.EndsWith("}")) return false;
        return s.Contains("\"ui\"");
    }

    // Broader detector so CTA shows for more phrasing styles
    bool IsFinalSummaryAskBubble(string rawLower){
        if (string.IsNullOrWhiteSpace(rawLower)) return false;

        bool hasSummaryLabels =
            rawLower.Contains("date and time") ||
            rawLower.Contains("room:") ||
            rawLower.Contains("layout:") ||
            rawLower.Contains("setup style") ||
            rawLower.Contains("event type") ||
            rawLower.Contains("equipment:") ||
            rawLower.Contains("audio visual:") ||
            rawLower.Contains("ceiling sound system") ||
            rawLower.Contains("technical support") ||
            rawLower.Contains("rehearsal") ||
            rawLower.Contains("number of speakers") ||
            rawLower.Contains("number of presenters") ||
            rawLower.Contains("attendees") ||
            rawLower.Contains("guests:") ||
            rawLower.Contains("purpose") ||
            rawLower.Contains("goal:");

        if(!hasSummaryLabels) return false;

        bool asksToConfirm =
            rawLower.Contains("does this look correct") ||
            rawLower.Contains("does everything look correct") ||
            rawLower.Contains("can you confirm") ||
            rawLower.Contains("please confirm") ||
            rawLower.Contains("before i create your quote") ||
            rawLower.Contains("before creating your quote") ||
            rawLower.Contains("before i prepare your quote") ||
            rawLower.Contains("ready for me to create the quote") ||
            rawLower.Contains("should i create the quote") ||
            rawLower.Contains("would you like me to create the quote");

        return asksToConfirm;
    }

    // Shapes for galleries
    public class IslaGallery{ public string? Room{get;set;} public List<IslaGalleryItem>? Items{get;set;} }
    public class IslaGalleryItem{ public string? Kind{get;set;} public string? Label{get;set;} public string? Url{get;set;} public object? Select{get;set;} }
}

<script id="isla-chat-binder">
(function(){
  // prevent double-binding if this partial gets swapped repeatedly
  if (window.__islaChatBound) return;
  window.__islaChatBound = true;

  function getCsrf(){
    const el=document.querySelector('input[name="__RequestVerificationToken"]');
    return el?el.value:'';
  }
  function showBusy(btn){
    if(!btn) return;
    btn.classList.add('isla-busy'); btn.disabled=true;
    if(!btn.querySelector('.isla-spinner')){
      const sp=document.createElement('span');
      sp.className='isla-spinner'; sp.setAttribute('aria-hidden','true'); btn.appendChild(sp);
    }
  }
  function addThinkingUnder(el){
    if(!el) return;
    const host=el.closest('.isla-timepicker, .isla-multitime, .isla-timechips, .isla-gallery, .isla-cta')||el.parentElement;
    if(!host || host.querySelector('.isla-thinking')) return;
    const line=document.createElement('div'); line.className='isla-thinking'; line.textContent='Isla is thinking…'; host.appendChild(line);
  }
  async function postChat(text,busyEl){
    try{
      showBusy(busyEl); addThinkingUnder(busyEl);
      const token=getCsrf();
      const resp=await fetch('/Chat/SendPartial',{
        method:'POST',
        headers:{
          'Content-Type':'application/x-www-form-urlencoded; charset=UTF-8',
          'RequestVerificationToken': token
        },
        body:new URLSearchParams({ text })
      });
      const html=await resp.text();
      const host=document.getElementById('messagesWrap')||
                  document.querySelector('#messages, .messages, .chat-transcript')||null;
      if(host){ host.innerHTML=html; host.scrollTop=host.scrollHeight; }
      else{ document.body.innerHTML=html; }
    }catch(e){ console.error('send failed',e); alert('Something went wrong. Please try again.'); }
  }

  // Delegated handlers that survive DOM replacement
  document.addEventListener('click',(ev)=>{
    const btn=ev.target.closest('.isla-card'); if(!btn) return;
    const raw=btn.getAttribute('data-select')||'{}'; let obj={}; try{obj=JSON.parse(raw);}catch{}
    let text=''; if(obj.room) text=`Choose room: ${obj.room}`; if(obj.layout) text=`Choose layout: ${obj.layout}`;
    if(text) postChat(text,btn);
  },{passive:true});

  document.addEventListener('click',(ev)=>{
    const chip=ev.target.closest('.isla-chip'); if(!chip) return;
    const val=chip.getAttribute('data-text'); if(val) postChat(`Choose time: ${val}`,chip);
  },{passive:true});

  document.addEventListener('click',(ev)=>{
    const wrap=ev.target.closest('.isla-timepicker'); if(!wrap) return;
    const btn=ev.target.closest('.btn-apply-time'); if(!btn) return;
    const s=wrap.querySelector('.tp-start')?.value||''; const e=wrap.querySelector('.tp-end')?.value||'';
    if(!s||!e) return; postChat(`Choose time: ${s}–${e}`,btn);
  },{passive:false}); // need cancelability for buttons

  document.addEventListener('click',(ev)=>{
    const wrap=ev.target.closest('.isla-multitime'); if(!wrap) return;
    const btn=ev.target.closest('.btn-apply-multitime'); if(!btn) return;
    const inputs=wrap.querySelectorAll('.mt-input'); if(!inputs||inputs.length===0) return;
    const vals={}; inputs.forEach(i=>{ const n=(i.getAttribute('data-name')||'').trim().toLowerCase(); const v=(i.value||'').trim(); if(n&&v) vals[n]=v; });
    const setup=vals['setup']||'', rehearsal=vals['rehearsal']||'', start=vals['start']||'', end=vals['end']||'';
    const packup=vals['packup']||vals['pack_down']||vals['packdown']||'';
    const parts=[]; if(setup)parts.push(`setup=${setup}`); if(rehearsal)parts.push(`rehearsal=${rehearsal}`);
    if(start)parts.push(`start=${start}`); if(end)parts.push(`end=${end}`); if(packup)parts.push(`packup=${packup}`);
    if(parts.length) postChat(`Choose schedule: ${parts.join('; ')}`,btn);
  },{passive:false});

  document.addEventListener('click',(ev)=>{
    const yes=ev.target.closest('.isla-quote-yes'); if(!yes) return;
    ev.preventDefault(); ev.stopPropagation(); postChat('yes create quote', yes);
  },{passive:false});

  document.addEventListener('click',(ev)=>{
    const no=ev.target.closest('.isla-quote-no'); if(!no) return;
    ev.preventDefault(); ev.stopPropagation(); postChat('no, not yet', no);
  },{passive:false});
})();
</script>

